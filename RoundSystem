local ServerScriptService = game:GetService("ServerScriptService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local Teams = game:GetService("Teams") 

-- Dependencies
local ServiceRegistry = require(ServerScriptService:WaitForChild("ServiceRegistry"))
local RoundEvents = require(ServerScriptService:WaitForChild("RoundEvents"))

-- Services
local MapService = ServiceRegistry.Await("MapService")
local TeamService = ServiceRegistry.Await("TeamService")
local TimerService = ServiceRegistry.Await("TimerService")
local RewardTracker = ServiceRegistry.Await("RewardTracker")
local RelevanceSystem = ServiceRegistry.Await("RelevanceSystem")

-- Config
local MIN_PLAYERS = 2
local ROUND_DURATION = 300 

-- State Tracking
local roundWinner = nil
local roundActive = false

-- ── Win Condition Logic ──
local function CheckWinCondition()
	if not roundActive then return end

	local designersTeam = Teams:FindFirstChild("Designers")
	local criticsTeam = Teams:FindFirstChild("Critics")

	local aliveDesigners = designersTeam and #designersTeam:GetPlayers() or 0
	local aliveCritics = criticsTeam and #criticsTeam:GetPlayers() or 0

	local allDesignersFrozen = ReplicatedStorage:GetAttribute("AllDesignersFrozen")
	local allCriticsFrozen = ReplicatedStorage:GetAttribute("AllCriticsFrozen")

	-- Get dynamic target score from MatchRegistry
	local MatchRegistry = ServiceRegistry.Get("MatchRegistry")
	local targetScore = MatchRegistry and MatchRegistry.GetTargetScore() or 5

	-- Get current scores from FabricManager
	local FabricManager = ServiceRegistry.Get("FabricManager")
	local designerScore = FabricManager and FabricManager.GetDesignerScore() or 0
	local criticScore = FabricManager and FabricManager.GetCriticScore() or 0

	-- 1. SCORE-BASED WIN: Either team reaches target
	if designerScore >= targetScore then
		roundWinner = "Designers"
		roundActive = false
		print("[ROUND] Designers win by reaching " .. targetScore .. " fabric!")
		return
	end
	if criticScore >= targetScore then
		roundWinner = "Critics"
		roundActive = false
		print("[ROUND] Critics win by reaching " .. targetScore .. " shreds!")
		return
	end

	-- 2. FREEZE WIPE: Last Team Standing
	if allDesignersFrozen or aliveDesigners == 0 then
		roundWinner = "Critics"
		roundActive = false
		print("[ROUND] Critics win - all Designers frozen!")
		return
	end
	if allCriticsFrozen or aliveCritics == 0 then
		roundWinner = "Designers"
		roundActive = false
		print("[ROUND] Designers win - all Critics frozen!")
		return
	end

	-- 3. DRAW: Not enough players
	if #Players:GetPlayers() < MIN_PLAYERS then
		roundWinner = "Draw"
		roundActive = false
		return
	end
end

-- Event Listeners (Connect once, stays active)
ReplicatedStorage:GetAttributeChangedSignal("AllDesignersFrozen"):Connect(CheckWinCondition)
ReplicatedStorage:GetAttributeChangedSignal("AllCriticsFrozen"):Connect(CheckWinCondition)
Teams.ChildAdded:Connect(CheckWinCondition)
Teams.ChildRemoved:Connect(CheckWinCondition)
Players.PlayerRemoving:Connect(CheckWinCondition)

-- ── The Main Game Loop ──
local function StartRoundLoop()
	while true do
		-- Reset state for the new cycle
		roundWinner = nil
		roundActive = false
		ReplicatedStorage:SetAttribute("AllDesignersFrozen", false)
		ReplicatedStorage:SetAttribute("AllCriticsFrozen", false)

		-- Reset scores
		local FabricManager = ServiceRegistry.Get("FabricManager")
		if FabricManager then FabricManager.ResetScores() end

		TeamService.ResetTeams()
		MapService.Cleanup()

		-- Wait for enough players
		while #Players:GetPlayers() < MIN_PLAYERS do
			TimerService.SetStatus("Waiting for Players...")
			task.wait(2)
		end

		-- Intermission
		RoundEvents.FireIntermission()
		TimerService.StartCountdown(10, "Intermission")
		task.wait(10) 

		-- Setup phase
		TimerService.SetStatus("Selecting Map...")
		local map = MapService.SelectAndLoadMap()
		local critics, designers = TeamService.AssignTeams()

		RoundEvents.FireRoundStarted({ Critics = critics, Designers = designers })
		task.wait(5)

		-- Spawn 'em in
		MapService.TeleportPlayers(designers, MapService.GetSpawns(map, "DesignerSpawn"))
		MapService.TeleportPlayers(critics, MapService.GetSpawns(map, "CriticSpawn"))

		-- GO LIVE
		roundActive = true
		TimerService.StartCountdown(ROUND_DURATION, "The Show is Live!", function()
			-- Timer expired callback: TIE-BREAKER - Most fabric wins
			if roundActive then
				local FabricManager = ServiceRegistry.Get("FabricManager")
				local dScore = FabricManager and FabricManager.GetDesignerScore() or 0
				local cScore = FabricManager and FabricManager.GetCriticScore() or 0

				if dScore > cScore then
					roundWinner = "Designers"
					print("[ROUND] Timer expired - Designers win with " .. dScore .. " vs " .. cScore)
				elseif cScore > dScore then
					roundWinner = "Critics"
					print("[ROUND] Timer expired - Critics win with " .. cScore .. " vs " .. dScore)
				else
					roundWinner = "Draw"
					print("[ROUND] Timer expired - Draw! Both teams tied at " .. dScore)
				end
				roundActive = false
			end
		end)

		-- Yield the loop until an event or timer sets roundActive to false
		repeat task.wait(0.1) until not roundActive

		TimerService.Stop()

		-- Post-Round Logic
		if roundWinner == "Critics" then
			print("[ROUND] Critics won. Initiating mass cancellation...")
			RelevanceSystem.CancelAllDesigners()
		elseif roundWinner == "Designers" then
			print("[ROUND] Designers won. Initiating mass cancellation...")
			RelevanceSystem.CancelAllCritics()
		end

		-- Dynamic UI Status
		local winStatus = "NO CONTEST"
		if roundWinner == "Critics" then
			winStatus = "CRITICS SHUT IT DOWN!"
		elseif roundWinner == "Designers" then
			winStatus = "THE COLLECTION IS A HIT!"
		end

		TimerService.SetStatus(winStatus)

		-- Send out rewards/recap data
		RoundEvents.FireRoundEnded({
			WinnerTeam = roundWinner,
			Critics = critics,
			TopDesigners = RewardTracker.GetTopPerformers(3)
		})

		-- Victory/Defeat screen cooldown
		task.wait(15) 
	end
end

-- Kick it off
task.spawn(StartRoundLoop)
