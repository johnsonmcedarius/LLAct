-- RoundSystem (Script in ServerScriptService)
-- Phase 3: win rewards use RewardTracker, MVP teleport to MVPPodiumAttachment,
-- fires ShowMVP remote for client slow-zoom camera sequence.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players           = game:GetService("Players")
local Workspace         = game:GetService("Workspace")
local Teams             = game:GetService("Teams")

local StatusValues = ReplicatedStorage:WaitForChild("StatusValues")
local StatusText   = StatusValues:WaitForChild("StatusText")
local TimerValue   = StatusValues:WaitForChild("Timer")

local MapsFolder  = ReplicatedStorage:WaitForChild("Maps")
local LobbyTeam   = Teams:WaitForChild("Lobby")
local DesignersTeam = Teams:WaitForChild("Designers")
local CriticsTeam   = Teams:WaitForChild("Critics")

local Remotes = ReplicatedStorage:WaitForChild("Remotes")

local function getRemote(name)
	local r = Remotes:FindFirstChild(name)
	if not r then r = Instance.new("RemoteEvent", Remotes) r.Name = name end
	return r
end

local ShowMVP    = getRemote("ShowMVP")
local ShowEndStats = getRemote("ShowEndStats")

-- Settings
local INTERMISSION_TIME = 10
local ROUND_TIME        = 300
local MIN_PLAYERS       = 2

local currentMapModel = nil
local lobbySpawn      = Workspace:FindFirstChild("LobbySpawn")

-------------------------------------------------
-- Timer format
-------------------------------------------------
local function formatTime(seconds)
	return string.format("%d:%02d", math.floor(seconds / 60), seconds % 60)
end

-------------------------------------------------
-- Helpers
-------------------------------------------------
local function teleportPlayers(list, targetCFrame)
	for _, p in pairs(list) do
		if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
			local offset = Vector3.new(math.random(-3, 3), 3, math.random(-3, 3))
			p.Character:PivotTo(targetCFrame + offset)
		end
	end
end

local function resetTeams()
	for _, p in pairs(Players:GetPlayers()) do
		p.Team = LobbyTeam
	end
end

-------------------------------------------------
-- MVP podium teleport
-------------------------------------------------
local function teleportMVPToLobbyPodium(mvpPlayer)
	-- Find MVPPodium model in lobby (anywhere in workspace)
	local mvpPodium = Workspace:FindFirstChild("MVPPodium", true)
	if not mvpPodium then
		warn("[MVP] MVPPodium model not found in Workspace.")
		return
	end

	local attachment = mvpPodium:FindFirstChild("MVPPodiumAttachment", true)
	if not attachment then
		warn("[MVP] MVPPodiumAttachment not found inside MVPPodium.")
		return
	end

	if mvpPlayer.Character and mvpPlayer.Character:FindFirstChild("HumanoidRootPart") then
		mvpPlayer.Character:PivotTo(attachment.WorldCFrame)
		print("[MVP] " .. mvpPlayer.Name .. " teleported to MVP podium.")
	end
end

-------------------------------------------------
-- Main loop
-------------------------------------------------
while true do
	ReplicatedStorage:SetAttribute("AllDesignersFrozen", false)

	resetTeams()
	if currentMapModel then
		currentMapModel:Destroy()
		currentMapModel = nil
	end

	-- Wait for players
	while #Players:GetPlayers() < MIN_PLAYERS do
		StatusText.Value = "Waiting for players... (Need " .. MIN_PLAYERS .. "+)"
		TimerValue.Value = 0
		task.wait(1)
	end

	-- Intermission
	for i = INTERMISSION_TIME, 0, -1 do
		StatusText.Value = "Intermission"
		TimerValue.Value = i
		task.wait(1)
	end

	StatusText.Value = "Selecting Map..."
	task.wait(1)

	local maps = MapsFolder:GetChildren()
	if #maps > 0 then
		local map = maps[math.random(#maps)]
		currentMapModel = map:Clone()
		currentMapModel.Parent = Workspace

		local designerSpawn = currentMapModel:FindFirstChild("Spawn")
		local criticSpawn   = currentMapModel:FindFirstChild("CriticSpawn") or designerSpawn

		if designerSpawn then
			local all       = Players:GetPlayers()
			local numCritics = #all >= 4 and 2 or 1

			-- Shuffle
			for i = #all, 2, -1 do
				local j = math.random(i)
				all[i], all[j] = all[j], all[i]
			end

			local criticNames = {}
			for i = 1, numCritics do
				all[i].Team = CriticsTeam
				table.insert(criticNames, all[i].Name)
			end
			for i = numCritics + 1, #all do
				all[i].Team = DesignersTeam
			end

			if #criticNames == 1 then
				StatusText.Value = criticNames[1] .. " is the Critic!"
			else
				StatusText.Value = criticNames[1] .. " AND " .. criticNames[2] .. " are the Critics!"
			end

			task.wait(2.5)
			StatusText.Value = "Game Starting..."
			task.wait(1)

			pcall(function()
				teleportPlayers(DesignersTeam:GetPlayers(), designerSpawn.CFrame)
				teleportPlayers(CriticsTeam:GetPlayers(), criticSpawn.CFrame)
			end)

			-- Round loop
			local roundWinner = nil

			for i = ROUND_TIME, 0, -1 do
				local dCount    = #DesignersTeam:GetPlayers()
				local cCount    = #CriticsTeam:GetPlayers()
				local allFrozen = ReplicatedStorage:GetAttribute("AllDesignersFrozen")

				if allFrozen then
					StatusText.Value = "Critics Win! The runway is shut down."
					roundWinner = "Critics"
					break
				elseif dCount == 0 then
					StatusText.Value = "Critics Win! No designers left."
					roundWinner = "Critics"
					break
				elseif cCount == 0 then
					StatusText.Value = "Designers Win! Critics left."
					roundWinner = "Designers"
					break
				elseif #Players:GetPlayers() < MIN_PLAYERS then
					StatusText.Value = "Not enough players!"
					break
				end

				if i == 0 then
					StatusText.Value = "The Collection is a Hit!"
					roundWinner = "Designers"
				else
					StatusText.Value = "Round  " .. formatTime(i)
				end

				TimerValue.Value = i
				task.wait(1)
			end

			-- End round via RewardTracker
			-- (RewardTracker listens to StatusText "Win" keywords)
			-- Give time for RewardTracker to fire MVP event
			task.wait(4)

			-- The MVP teleport happens here after RewardTracker fires ShowMVP
			-- We find the MVP from Workspace (teleported by RewardTracker)
			-- RewardTracker fires ShowMVP:FireAllClients(mvpName, mvpUserId, mvpTitle)
			-- This script just ensures cleanup happens after 15 seconds

			task.wait(15) -- MVP camera + stats screen window
		end
	end

	-- Cleanup
	task.wait(1)
	StatusText.Value = "Round Over!"
	print("[SYSTEM] Round ended. Cleaning up.")

	for _, p in pairs(Players:GetPlayers()) do
		local toolInChar = p.Character and p.Character:FindFirstChild("FBRoll")
		if toolInChar then toolInChar:Destroy() end
		local toolInBp = p.Backpack:FindFirstChild("FBRoll")
		if toolInBp then toolInBp:Destroy() end
		p:LoadCharacter()
	end

	if lobbySpawn then
		teleportPlayers(Players:GetPlayers(), lobbySpawn.CFrame)
	else
		warn("[ROUND] LobbySpawn missing!")
	end

	task.wait(2)
end
