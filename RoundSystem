local ServerScriptService = game:GetService("ServerScriptService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local Teams = game:GetService("Teams") 

-- Dependencies
local ServiceRegistry = require(ServerScriptService:WaitForChild("ServiceRegistry"))
local RoundEvents = require(ServerScriptService:WaitForChild("RoundEvents"))

-- Services
local MapService = ServiceRegistry.Await("MapService")
local TeamService = ServiceRegistry.Await("TeamService")
local TimerService = ServiceRegistry.Await("TimerService")
local RewardTracker = ServiceRegistry.Await("RewardTracker")
local RelevanceSystem = ServiceRegistry.Await("RelevanceSystem")

-- Config
local MIN_PLAYERS = 2
local ROUND_DURATION = 300 

local function StartRoundLoop()
	while true do
		-- 1. Reset state for the new round
		ReplicatedStorage:SetAttribute("AllDesignersFrozen", false)
		TeamService.ResetTeams()
		MapService.Cleanup()
		
		while #Players:GetPlayers() < MIN_PLAYERS do
			TimerService.SetStatus("Waiting for Players...")
			task.wait(2)
		end
		
		-- 2. Intermission
		RoundEvents.FireIntermission()
		TimerService.StartCountdown(10, "Intermission")
		task.wait(10) 
		
		-- 3. Map Selection & Team Assignment
		TimerService.SetStatus("Selecting Map...")
		local map = MapService.SelectAndLoadMap()
		local critics, designers = TeamService.AssignTeams() -- Dynamic counts via TeamService
		
		-- 4. Intro Sequence
		RoundEvents.FireRoundStarted({ Critics = critics, Designers = designers })
		task.wait(5)
		
		-- 5. Spawning
		MapService.TeleportPlayers(designers, MapService.GetSpawns(map, "DesignerSpawn"))
		MapService.TeleportPlayers(critics, MapService.GetSpawns(map, "CriticSpawn"))
		
		local roundWinner = nil
		local roundOver = false
		
		-- 6. Main Game Clock: If it finishes, Designers win by default
		TimerService.StartCountdown(ROUND_DURATION, "The Show is Live!", function()
			if not roundOver then
				roundWinner = "Designers"
				roundOver = true
			end
		end)
		
		-- ── Main Win Condition Check ──
		-- Polling at 0.5s for instant win detection
		while not roundOver do
			local designersTeam = Teams:FindFirstChild("Designers")
			local aliveDesigners = designersTeam and #designersTeam:GetPlayers() or 0
			local allFrozen = ReplicatedStorage:GetAttribute("AllDesignersFrozen")
			
			-- CRITICAL WIN: Only if everyone is caught/frozen
			if allFrozen or aliveDesigners == 0 then
				roundWinner = "Critics"
				roundOver = true
			elseif #Players:GetPlayers() < MIN_PLAYERS then
				roundWinner = "Draw"
				roundOver = true
			end
			task.wait(0.5)
		end
		
		TimerService.Stop()
		
		-- // THE CANCELLATION TRIGGER // --
		if roundWinner == "Critics" then
			print("[ROUND] Critics won. Initiating mass cancellation...")
			RelevanceSystem.CancelAllDesigners() 
		end
		
		-- Updated dynamic status messages
		local winStatus = (roundWinner == "Critics") and "CRITICS SHUT IT DOWN!" or "THE COLLECTION IS A HIT!"
		TimerService.SetStatus(winStatus)
		
		-- 7. Victory Data Gathering
		local victoryData = {
			WinnerTeam = roundWinner,
			Critics = critics,
			TopDesigners = RewardTracker.GetTopPerformers(3)
		}
		
		RoundEvents.FireRoundEnded(victoryData)
		
		-- Wait for Victory UI/Recap
		task.wait(15) 
	end
end

task.spawn(StartRoundLoop)
