local ServerScriptService = game:GetService("ServerScriptService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

-- Dependencies
local ServiceRegistry = require(ServerScriptService:WaitForChild("ServiceRegistry"))
local RoundEvents = require(ServerScriptService:WaitForChild("RoundEvents"))

-- Services
local MapService = ServiceRegistry.Await("MapService")
local TeamService = ServiceRegistry.Await("TeamService")
local TimerService = ServiceRegistry.Await("TimerService")
local RewardTracker = ServiceRegistry.Await("RewardTracker")

-- Config (Dynamic & Changeable)
local MIN_PLAYERS = 2
local INTERMISSION_TIME = 15
local ROUND_DURATION = 300

-- Team Settings (Adjustable on the fly)
local SETTINGS = {
	CriticCount = 2, -- Default for 10 players
	DesignerCount = 8
}

local function StartRoundLoop()
	while true do
		-- 1. Reset
		TeamService.ResetTeams()
		MapService.Cleanup()
		ReplicatedStorage:SetAttribute("AllDesignersFrozen", false)

		while #Players:GetPlayers() < MIN_PLAYERS do
			TimerService.SetStatus("Waiting for Players ("..#Players:GetPlayers().."/"..MIN_PLAYERS..")")
			task.wait(2)
		end

		RoundEvents.FireIntermission()

		local intermissionOver = false
		TimerService.StartCountdown(INTERMISSION_TIME, "Intermission", function()
			intermissionOver = true
		end)

		repeat task.wait() until intermissionOver

		-- 2. Map Selection
		TimerService.SetStatus("Selecting Map...")
		local map = MapService.SelectAndLoadMap()
		task.wait(2)

		-- 3. Team Assignment (Uses dynamic counts)
		local critics, designers = TeamService.AssignTeams(SETTINGS.CriticCount)

		-- 4. Intro "VS" Sequence
		-- We pass the player lists to the client so the UI can show the match-up
		RoundEvents.FireRoundStarted({
			Critics = critics,
			Designers = designers
		})

		TimerService.SetStatus("MATCH STARTING")
		task.wait(5) -- Give time for the VS UI animation

		-- 5. Spawning
		local dSpawns = MapService.GetSpawns(map, "DesignerSpawn")
		local cSpawns = MapService.GetSpawns(map, "CriticSpawn")

		MapService.TeleportPlayers(designers, dSpawns)
		MapService.TeleportPlayers(critics, cSpawns)

		-- 6. Main Game Loop
		local roundWinner = nil
		local roundOver = false

		TimerService.StartCountdown(ROUND_DURATION, "Runway in Session", function()
			roundWinner = "Designers" -- Time ran out, Designers win
			roundOver = true
		end)

		while not roundOver do
			local aliveDesigners = #designers -- You might want to filter for actually "active" players here
			local allFrozen = ReplicatedStorage:GetAttribute("AllDesignersFrozen")

			if allFrozen or aliveDesigners == 0 then
				roundWinner = "Critics"
				roundOver = true
			elseif #Players:GetPlayers() < MIN_PLAYERS then
				roundWinner = "Draw"
				roundOver = true
			end
			task.wait(1)
		end

		TimerService.Stop()
		TimerService.SetStatus(roundWinner .. " Win!")

		-- 7. Winning Data Gathering
		local victoryData = {
			WinnerTeam = roundWinner,
			Critics = critics,
			TopDesigners = RewardTracker.GetTopPerformers(3) -- Get top 3 Designers by fabric dunks
		}

		RoundEvents.FireRoundEnded(victoryData)

		task.wait(15) -- Time for the Victory Screen and End Stats
	end
end

task.spawn(StartRoundLoop)
