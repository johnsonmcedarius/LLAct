-- TrendTrackerController (LocalScript in StarterPlayerScripts)
-- FIXED:
--   Removed the RunService.Heartbeat loop that scanned every player's backpack/character
--   every single frame. Replaced with CollectionService tag signals:
--     - Server tags a Designer "HoldingFabric" when they pick up FBRoll
--     - Server removes the tag when they lose it
--   Client just listens to GetInstanceAddedSignal / GetInstanceRemovedSignal.
--   Zero per-frame math.

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CollectionService = game:GetService("CollectionService")

local player = Players.LocalPlayer

local Remotes              = ReplicatedStorage:WaitForChild("Remotes")
local TrendTrackerActivate = Remotes:WaitForChild("TrendTrackerActivate")

-- State
local trendTrackerActive = false
local expiryTask         = nil
local auraObjects        = {}  -- [character] = Highlight

-------------------------------------------------
-- Aura helpers
-------------------------------------------------
local function applyAura(character)
	if auraObjects[character] then return end

	local highlight = Instance.new("Highlight")
	highlight.Adornee            = character
	highlight.OutlineColor       = Color3.fromRGB(255, 80, 200)
	highlight.FillColor          = Color3.fromRGB(255, 80, 200)
	highlight.FillTransparency   = 0.85
	highlight.OutlineTransparency = 0
	highlight.DepthMode          = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent             = character

	auraObjects[character] = highlight
end

local function removeAura(character)
	local h = auraObjects[character]
	if h then
		h:Destroy()
		auraObjects[character] = nil
	end
end

local function clearAllAuras()
	for char, h in pairs(auraObjects) do
		h:Destroy()
		auraObjects[char] = nil
	end
end

-------------------------------------------------
-- Helper: get character from a tagged instance
-- The server tags the CHARACTER MODEL with "HoldingFabric"
-------------------------------------------------
local function getPlayerFromCharacter(char)
	return Players:GetPlayerFromCharacter(char)
end

-------------------------------------------------
-- CollectionService listeners
-- These fire instantly when a tag is added/removed — no polling needed.
-------------------------------------------------
CollectionService:GetInstanceAddedSignal("HoldingFabric"):Connect(function(char)
	if not trendTrackerActive then return end

	-- Only apply if the local player is a Critic
	if not (player.Team and player.Team.Name == "Critics") then return end

	-- Don't highlight the local player themselves
	local targetPlayer = getPlayerFromCharacter(char)
	if targetPlayer == player then return end

	-- Only highlight Designers
	if not (targetPlayer and targetPlayer.Team and targetPlayer.Team.Name == "Designers") then return end

	applyAura(char)
end)

CollectionService:GetInstanceRemovedSignal("HoldingFabric"):Connect(function(char)
	removeAura(char)
end)

-------------------------------------------------
-- Activation: server fires this only to Critics
-------------------------------------------------
TrendTrackerActivate.OnClientEvent:Connect(function(duration)
	print("[TREND TRACKER] Activated for " .. duration .. " seconds!")

	trendTrackerActive = true

	-- Cancel any previous expiry
	if expiryTask then task.cancel(expiryTask) end

	-- Immediately highlight all currently tagged Designers
	if player.Team and player.Team.Name == "Critics" then
		for _, char in ipairs(CollectionService:GetTagged("HoldingFabric")) do
			local targetPlayer = getPlayerFromCharacter(char)
			if targetPlayer and targetPlayer ~= player
				and targetPlayer.Team and targetPlayer.Team.Name == "Designers" then
				applyAura(char)
			end
		end
	end

	-- Auto-expire
	expiryTask = task.delay(duration, function()
		trendTrackerActive = false
		clearAllAuras()
		print("[TREND TRACKER] Expired.")
	end)
end)

-- Cleanup on character reset
player.CharacterAdded:Connect(function()
	clearAllAuras()
	trendTrackerActive = false
	if expiryTask then task.cancel(expiryTask) expiryTask = nil end
end)
