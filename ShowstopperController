-- ShowstopperController (LocalScript in StarterPlayerScripts)
-- Handles: showstopper input (F / Xbox Y / Mobile), charge bar update forwarding,
-- and charge-full flash effect. UI elements are expected in GameHUD ScreenGui.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ContextActionService = game:GetService("ContextActionService")
local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer

local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))

local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local ActivateShowstopper    = Remotes:WaitForChild("ActivateShowstopper")
local UpdateShowstopperCharge = Remotes:WaitForChild("UpdateShowstopperCharge")
local ShowstopperFullAlert   = Remotes:WaitForChild("ShowstopperFullAlert")

local currentCharge = 0
local maxCharge = 100
local isReady = false

-------------------------------------------------
-- Activation input
-------------------------------------------------
local SHOWSTOPPER_ACTION = "ActivateShowstopper"

ContextActionService:BindAction(
	SHOWSTOPPER_ACTION,
	function(_, inputState)
		if inputState ~= Enum.UserInputState.Begin then return end
		if not isReady then
			print("[SHOWSTOPPER] Not ready yet: " .. currentCharge .. "/" .. maxCharge)
			return
		end
		print("[SHOWSTOPPER] Firing showstopper!")
		ActivateShowstopper:FireServer(nil) -- nil = use team default
	end,
	true,              -- create mobile button
	Enum.KeyCode.F,
	Enum.KeyCode.ButtonY
)

local mobileBtn = ContextActionService:GetButton(SHOWSTOPPER_ACTION)
if mobileBtn then
	mobileBtn.Text = "SHOW"
	mobileBtn.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
	mobileBtn.BackgroundTransparency = 0.2
end

-------------------------------------------------
-- Charge sync + bar update
-- Charge bar lives in HUDController but we track state here too
-------------------------------------------------
UpdateShowstopperCharge.OnClientEvent:Connect(function(charge, max)
	currentCharge = charge
	maxCharge = max
	isReady = (charge >= max)

	-- Enable/disable mobile button visually
	if mobileBtn then
		mobileBtn.BackgroundColor3 = isReady
			and Color3.fromRGB(255, 80, 200)
			or Color3.fromRGB(120, 120, 120)
	end
end)

ShowstopperFullAlert.OnClientEvent:Connect(function()
	isReady = true
	print("[SHOWSTOPPER] Charge full. Ready to activate!")

	-- HUDController handles the visual flash.
	-- Here we just update the mobile button.
	if mobileBtn then
		mobileBtn.BackgroundColor3 = Color3.fromRGB(255, 80, 200)
	end
end)
