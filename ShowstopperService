-- ShowstopperService (Script in ServerScriptService)
-- FIXED: Registers via ServiceRegistry instead of _G.ShowstopperService
-- Round reset now uses RoundEvents instead of StatusText string matching.

local Players             = game:GetService("Players")
local ReplicatedStorage   = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")

local ServiceRegistry = require(ServerScriptService:WaitForChild("ServiceRegistry"))
local RoundEvents     = require(ServerScriptService:WaitForChild("RoundEvents"))

local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))

local Remotes = ReplicatedStorage:WaitForChild("Remotes")

local ActivateShowstopper    = Remotes:FindFirstChild("ActivateShowstopper")    or Instance.new("RemoteEvent", Remotes)
ActivateShowstopper.Name     = "ActivateShowstopper"
local UpdateShowstopperCharge = Remotes:FindFirstChild("UpdateShowstopperCharge") or Instance.new("RemoteEvent", Remotes)
UpdateShowstopperCharge.Name  = "UpdateShowstopperCharge"
local ShowstopperFullAlert    = Remotes:FindFirstChild("ShowstopperFullAlert")    or Instance.new("RemoteEvent", Remotes)
ShowstopperFullAlert.Name     = "ShowstopperFullAlert"

local ShowstoppersFolder = ReplicatedStorage:WaitForChild("Showstoppers")

local MAX_CHARGE = 100

local ChargeAmounts = {
	FabricDunk     = 25,
	FabricPass     = 10,
	TeamRescue     = 15,
	AbilityHit     = 5,
	CloseDodge     = 3,
	FreezeDesigner = 20,
	FinalCancel    = 40,
	InterceptPass  = 15,
	DunkDenied     = 20,
}

local playerCharge  = {}
local cooldowns     = {}
local moduleCache   = {}
local chargeWasFull = {}

local function getCharge(player)
	return playerCharge[player.UserId] or 0
end

local function syncCharge(player)
	UpdateShowstopperCharge:FireClient(player, getCharge(player), MAX_CHARGE)
end

local function addCharge(player, amount)
	if not player or not player.Parent then return end

	local prev = getCharge(player)
	local new  = math.clamp(prev + amount, 0, MAX_CHARGE)
	playerCharge[player.UserId] = new
	syncCharge(player)

	if new >= MAX_CHARGE and not chargeWasFull[player.UserId] then
		chargeWasFull[player.UserId] = true
		ShowstopperFullAlert:FireClient(player)
		SoundService.FireToClient(player, "ShowstopperReady")
		print("[SHOWSTOPPER] " .. player.Name .. " charge is FULL!")
	end

	print("[SHOWSTOPPER] " .. player.Name .. " +" .. amount .. " charge -> " .. new)
end

local function resetCharge(player)
	playerCharge[player.UserId] = 0
	chargeWasFull[player.UserId] = nil
	syncCharge(player)
end

local function getModule(teamName, moduleName)
	local key = teamName .. "_" .. moduleName
	if moduleCache[key] then return moduleCache[key] end

	local folder = ShowstoppersFolder:FindFirstChild(teamName)
	if not folder then return nil end

	local ms = folder:FindFirstChild(moduleName)
	if not ms then return nil end

	local ok, result = pcall(require, ms)
	if ok then
		moduleCache[key] = result
		return result
	else
		warn("[SHOWSTOPPER] Failed to load " .. moduleName .. ": " .. tostring(result))
		return nil
	end
end

-- ── Public API ────────────────────────────────────────────────────────────────
local ShowstopperService = {
	AddCharge        = addCharge,
	GetCharge        = getCharge,
	ResetCharge      = resetCharge,

	OnFabricDunk     = function(player)           addCharge(player, ChargeAmounts.FabricDunk)     end,
	OnFabricPass     = function(passer, receiver)
		addCharge(passer,   ChargeAmounts.FabricPass)
		addCharge(receiver, ChargeAmounts.FabricPass)
	end,
	OnTeamRescue     = function(rescuer)          addCharge(rescuer, ChargeAmounts.TeamRescue)     end,
	OnAbilityHit     = function(player)           addCharge(player,  ChargeAmounts.AbilityHit)     end,
	OnCloseDodge     = function(player)           addCharge(player,  ChargeAmounts.CloseDodge)     end,
	OnFreezeDesigner = function(critic)           addCharge(critic,  ChargeAmounts.FreezeDesigner) end,
	OnFinalCancel    = function(critic)           addCharge(critic,  ChargeAmounts.FinalCancel)    end,
	OnInterceptPass  = function(critic)           addCharge(critic,  ChargeAmounts.InterceptPass)  end,
	OnDunkDenied     = function(critic)           addCharge(critic,  ChargeAmounts.DunkDenied)     end,
}

-- ── Activation handler ────────────────────────────────────────────────────────
ActivateShowstopper.OnServerEvent:Connect(function(player, moduleName)
	local charge = getCharge(player)
	if charge < MAX_CHARGE then
		print("[SHOWSTOPPER] " .. player.Name .. " tried to activate with " .. charge .. "/" .. MAX_CHARGE)
		return
	end

	local now = os.clock()
	if now < (cooldowns[player.UserId] or 0) then
		print("[SHOWSTOPPER] " .. player.Name .. " is on cooldown.")
		return
	end

	if not player.Team then return end
	local teamName = player.Team.Name

	local targetModule = moduleName
	if not targetModule then
		local folder = ShowstoppersFolder:FindFirstChild(teamName)
		if folder then
			local children = folder:GetChildren()
			if #children > 0 then targetModule = children[1].Name end
		end
	end

	if not targetModule then
		warn("[SHOWSTOPPER] No module for team: " .. teamName)
		return
	end

	local mod = getModule(teamName, targetModule)
	if not mod then return end

	print("[SHOWSTOPPER] " .. player.Name .. " fires " .. targetModule)
	local ok, err = pcall(mod.Execute, player)
	if not ok then
		warn("[SHOWSTOPPER] Execute error: " .. tostring(err))
		return
	end

	SoundService.FireToClient(player, "ShowstopperActivate")
	resetCharge(player)
	cooldowns[player.UserId] = now + (mod.Config.Cooldown or 60)
end)

-- ── Round reset via RoundEvents ───────────────────────────────────────────────
RoundEvents.Intermission.Event:Connect(function()
	for _, p in ipairs(Players:GetPlayers()) do
		resetCharge(p)
		cooldowns[p.UserId] = nil
	end
end)

Players.PlayerRemoving:Connect(function(player)
	playerCharge[player.UserId]  = nil
	cooldowns[player.UserId]     = nil
	chargeWasFull[player.UserId] = nil
end)

ServiceRegistry.Register("ShowstopperService", ShowstopperService)
return ShowstopperService
