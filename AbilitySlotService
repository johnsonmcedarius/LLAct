-- AbilitySlotService (Script in ServerScriptService)
-- FIXED: ServiceRegistry replaces _G.DataManager and _G.DailyLookbook

local Players             = game:GetService("Players")
local ReplicatedStorage   = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")

local ServiceRegistry = require(ServerScriptService:WaitForChild("ServiceRegistry"))
local DataManager     = ServiceRegistry.Await("DataManager")

local Remotes = ReplicatedStorage:WaitForChild("Remotes")

local function getRemote(name)
	local r = Remotes:FindFirstChild(name)
	if not r then r = Instance.new("RemoteEvent") r.Name = name r.Parent = Remotes end
	return r
end

local AbilitySlotUnlock  = getRemote("AbilitySlotUnlock")
local SpinAbility        = getRemote("SpinAbility")
local UpdateAbilitySlots = getRemote("UpdateAbilitySlots")

local SPIN_COST = 100

local AbilityPool = {
	{Name = "Hairspray Bomb",  Rarity = "Common",    Weight = 50},
	{Name = "Camera Flash",    Rarity = "Common",    Weight = 50},
	{Name = "High Heel Trap",  Rarity = "Common",    Weight = 50},
	{Name = "Double Spray",    Rarity = "Rare",      Weight = 25},
	{Name = "Chain Flash",     Rarity = "Rare",      Weight = 25},
	{Name = "Heel Storm",      Rarity = "Epic",      Weight = 10},
	{Name = "Fashion Surge",   Rarity = "Epic",      Weight = 10},
	{Name = "The Takedown",    Rarity = "Legendary", Weight = 4},
	{Name = "Style Shock",     Rarity = "Mythic",    Weight = 1},
}

local slotData = {}

local function getSlots(player)
	if not slotData[player.UserId] then
		local unlocked = player:GetAttribute("UnlockedAbilitySlots") or 1
		slotData[player.UserId] = {
			slots         = {nil, nil, nil},
			unlockedSlots = unlocked,
		}
	end
	return slotData[player.UserId]
end

local function syncToClient(player)
	local data = getSlots(player)
	UpdateAbilitySlots:FireClient(player, data.slots, data.unlockedSlots)
end

local function onUnlockedSlotsChanged(player)
	local unlocked = player:GetAttribute("UnlockedAbilitySlots") or 1
	local data = getSlots(player)
	if unlocked > data.unlockedSlots then
		data.unlockedSlots = unlocked
		syncToClient(player)
		AbilitySlotUnlock:FireClient(player, unlocked)
		print("[ABILITY] " .. player.Name .. " slot " .. unlocked .. " now active.")
	end
end

local function watchPlayer(player)
	player:GetAttributeChangedSignal("UnlockedAbilitySlots"):Connect(function()
		onUnlockedSlotsChanged(player)
	end)
end

local function spinAbility()
	local weighted = {}
	for _, ability in ipairs(AbilityPool) do
		for _ = 1, ability.Weight do table.insert(weighted, ability) end
	end
	return weighted[math.random(#weighted)]
end

SpinAbility.OnServerEvent:Connect(function(player, slotIndex)
	if type(slotIndex) ~= "number" then return end
	slotIndex = math.clamp(math.floor(slotIndex), 1, 3)

	local data = getSlots(player)
	if slotIndex > data.unlockedSlots then
		print("[ABILITY] " .. player.Name .. " slot " .. slotIndex .. " locked.")
		return
	end

	local coins = DataManager.GetCoins(player)
	if coins < SPIN_COST then
		print("[ABILITY] " .. player.Name .. " can't afford spin.")
		return
	end
	DataManager.AddCoins(player, -SPIN_COST)

	local result = spinAbility()
	data.slots[slotIndex] = result.Name

	print("[ABILITY] " .. player.Name .. " slot " .. slotIndex .. " -> " .. result.Name)
	syncToClient(player)

	local SpinResult = getRemote("AbilitySpinResult")
	SpinResult:FireClient(player, slotIndex, result)

	-- Optional dep
	local lb = ServiceRegistry.Get("DailyLookbook")
	if lb then lb.AddProgress(player, "Dashes", 1) end
end)

local AbilitySlotService = {
	GetSlots = function(player) return getSlots(player).slots end,
}

Players.PlayerAdded:Connect(function(player)
	task.wait(3)
	watchPlayer(player)
	syncToClient(player)
end)

for _, p in ipairs(Players:GetPlayers()) do
	watchPlayer(p)
	task.spawn(function() task.wait(3) syncToClient(p) end)
end

Players.PlayerRemoving:Connect(function(p)
	slotData[p.UserId] = nil
end)

ServiceRegistry.Register("AbilitySlotService", AbilitySlotService)
return AbilitySlotService
