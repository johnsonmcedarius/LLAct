-- AbilitySlotService (Script in ServerScriptService)
-- Slot 1: free for all players.
-- Slot 2: 149 Robux (Developer Product).
-- Slot 3: 149 Robux (Developer Product).
-- Spinning an ability costs Coins and randomly selects from a rarity-weighted pool.
-- Players cycle through selected abilities via AbilitySlotController on the client.

local Players            = game:GetService("Players")
local ReplicatedStorage  = game:GetService("ReplicatedStorage")
local MarketplaceService = game:GetService("MarketplaceService")

local Remotes = ReplicatedStorage:WaitForChild("Remotes")

local function getRemote(name)
	local r = Remotes:FindFirstChild(name)
	if not r then r = Instance.new("RemoteEvent") r.Name = name r.Parent = Remotes end
	return r
end

local AbilitySlotUnlock = getRemote("AbilitySlotUnlock")
local SpinAbility       = getRemote("SpinAbility")
local UpdateAbilitySlots = getRemote("UpdateAbilitySlots")
if not UpdateAbilitySlots then
	UpdateAbilitySlots = Instance.new("RemoteEvent")
	UpdateAbilitySlots.Name = "UpdateAbilitySlots"
	UpdateAbilitySlots.Parent = Remotes
end

-- Product IDs (replace with real ones)
local SLOT2_PRODUCT_ID = 0  -- 149 Robux
local SLOT3_PRODUCT_ID = 0  -- 149 Robux
local SPIN_COST        = 100 -- Coins per spin

-- Ability pool with rarity weights
local AbilityPool = {
	{Name = "Hairspray Bomb",   Rarity = "Common",    Weight = 50},
	{Name = "Camera Flash",     Rarity = "Common",    Weight = 50},
	{Name = "High Heel Trap",   Rarity = "Common",    Weight = 50},
	{Name = "Double Spray",     Rarity = "Rare",      Weight = 25},  -- Placeholder
	{Name = "Chain Flash",      Rarity = "Rare",      Weight = 25},  -- Placeholder
	{Name = "Heel Storm",       Rarity = "Epic",      Weight = 10},  -- Placeholder
	{Name = "Fashion Surge",    Rarity = "Epic",      Weight = 10},  -- Placeholder
	{Name = "The Takedown",     Rarity = "Legendary", Weight = 4},   -- Placeholder
	{Name = "Style Shock",      Rarity = "Mythic",    Weight = 1},   -- Placeholder
}

-- Per-player slot data: [userId] = {slots = {"AbilityName", nil, nil}, unlockedSlots = 1}
local slotData = {}

local function getSlots(player)
	if not slotData[player.UserId] then
		slotData[player.UserId] = {
			slots         = {nil, nil, nil},  -- 3 slot capacity
			unlockedSlots = 1,
		}
	end
	return slotData[player.UserId]
end

local function syncToClient(player)
	local data = getSlots(player)
	UpdateAbilitySlots:FireClient(player, data.slots, data.unlockedSlots)
end

-------------------------------------------------
-- Weighted spin
-------------------------------------------------
local function spinAbility()
	local weighted = {}
	for _, ability in ipairs(AbilityPool) do
		for _ = 1, ability.Weight do
			table.insert(weighted, ability)
		end
	end
	return weighted[math.random(#weighted)]
end

-------------------------------------------------
-- Spin handler
-------------------------------------------------
SpinAbility.OnServerEvent:Connect(function(player, slotIndex)
	if type(slotIndex) ~= "number" then return end
	slotIndex = math.clamp(math.floor(slotIndex), 1, 3)

	local data = getSlots(player)

	if slotIndex > data.unlockedSlots then
		print("[ABILITY] " .. player.Name .. " slot " .. slotIndex .. " not unlocked.")
		return
	end

	-- Deduct coins
	if not _G.DataManager then return end
	local coins = _G.DataManager.GetCoins(player)
	if coins < SPIN_COST then
		print("[ABILITY] " .. player.Name .. " can't afford spin.")
		return
	end
	_G.DataManager.AddCoins(player, -SPIN_COST)

	local result = spinAbility()
	data.slots[slotIndex] = result.Name

	print("[ABILITY] " .. player.Name .. " slot " .. slotIndex .. " -> " .. result.Name .. " (" .. result.Rarity .. ")")

	syncToClient(player)

	-- Notify client of spin result for UI animation
	local SpinResult = Remotes:FindFirstChild("AbilitySpinResult") or (function()
		local r = Instance.new("RemoteEvent") r.Name = "AbilitySpinResult" r.Parent = Remotes return r
	end)()
	SpinResult:FireClient(player, slotIndex, result)
end)

-------------------------------------------------
-- Slot unlock via Robux
-------------------------------------------------
local function processReceipt(receiptInfo)
	local player = Players:GetPlayerByUserId(receiptInfo.PlayerId)
	if not player then return Enum.ProductPurchaseDecision.NotProcessedYet end

	local pid = receiptInfo.ProductId

	if pid == SLOT2_PRODUCT_ID or pid == SLOT3_PRODUCT_ID then
		local data  = getSlots(player)
		local target = (pid == SLOT2_PRODUCT_ID) and 2 or 3

		if data.unlockedSlots >= target then
			print("[ABILITY] " .. player.Name .. " already has slot " .. target)
		else
			data.unlockedSlots = target
			print("[ABILITY] " .. player.Name .. " unlocked ability slot " .. target)
			syncToClient(player)
			AbilitySlotUnlock:FireClient(player, target)
		end
	end

	return Enum.ProductPurchaseDecision.PurchaseGranted
end

MarketplaceService.ProcessReceipt = processReceipt

-------------------------------------------------
-- Expose for other scripts
-------------------------------------------------
_G.AbilitySlotService = {
	GetSlots = function(player)
		return getSlots(player).slots
	end,
}

Players.PlayerAdded:Connect(function(player)
	-- Load slot data from DataManager if saved
	task.wait(2)  -- Wait for DataManager to load profile
	syncToClient(player)
end)

Players.PlayerRemoving:Connect(function(p)
	-- Optionally persist slots via DataManager here
	slotData[p.UserId] = nil
end)
