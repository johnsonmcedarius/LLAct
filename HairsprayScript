-- HairsprayScript (LocalScript inside Hairspray Tool)
-- DESIGNER ability. Throws a hairspray can projectile that explodes on impact.
-- VFX: trail while flying, explosion burst on land.
-- Slows Critics in explosion radius. Cooldown-gated.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Debris = game:GetService("Debris")

local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))

-- Config
local EXPLOSION_RADIUS = 10
local SLOW_DURATION = 5
local SLOW_MULTIPLIER = 0.5
local PROJECTILE_SPEED = 55
local PROJECTILE_LIFETIME = 5
local COOLDOWN = 8
local CRITIC_TEAM = "Critics"

local tool = script.Parent
local handle = tool:WaitForChild("Handle")

local debounce = false
local cooldownUntil = 0

-- Notify server for ability-hit charge
local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local AbilityHitRemote = Remotes:FindFirstChild("AbilityHit") or Instance.new("RemoteEvent", Remotes)
AbilityHitRemote.Name = "AbilityHit"

local CooldownUpdate = Remotes:FindFirstChild("AbilityCooldownUpdate") or Instance.new("RemoteEvent", Remotes)
CooldownUpdate.Name = "AbilityCooldownUpdate"

tool.Activated:Connect(function()
	local now = os.clock()
	if debounce or now < cooldownUntil then return end

	local char = tool.Parent
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	debounce = true
	cooldownUntil = now + COOLDOWN

	-- Notify HUD of cooldown start
	CooldownUpdate:FireServer("Hairspray", COOLDOWN)

	-- Play hiss sound locally
	SoundService.PlayLocal("HairsprayHiss")

	-- Build projectile
	local projectile = Instance.new("Part")
	projectile.Name = "HairsprayProjectile"
	projectile.Size = Vector3.new(0.4, 0.8, 0.4)
	projectile.BrickColor = BrickColor.new("Carnation pink")
	projectile.Material = Enum.Material.Neon
	projectile.CFrame = handle.CFrame
	projectile.CanCollide = false
	projectile.Parent = workspace

	-- Trail VFX
	local attachment0 = Instance.new("Attachment", projectile)
	local attachment1 = Instance.new("Attachment", projectile)
	attachment0.Position = Vector3.new(0, 0.4, 0)
	attachment1.Position = Vector3.new(0, -0.4, 0)

	local trail = Instance.new("Trail")
	trail.Attachment0 = attachment0
	trail.Attachment1 = attachment1
	trail.Lifetime = 0.3
	trail.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 100, 255)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 200, 255)),
	})
	trail.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0),
		NumberSequenceKeypoint.new(1, 1),
	})
	trail.Parent = projectile

	-- Particle in-flight
	local flightParticle = Instance.new("ParticleEmitter")
	flightParticle.Texture = "rbxasset://textures/particles/smoke_main.dds"
	flightParticle.Rate = 40
	flightParticle.Lifetime = NumberRange.new(0.2, 0.5)
	flightParticle.Speed = NumberRange.new(0, 1)
	flightParticle.Color = ColorSequence.new(Color3.fromRGB(255, 150, 255))
	flightParticle.Size = NumberSequence.new(0.3, 0)
	flightParticle.Parent = projectile

	-- Launch
	local bv = Instance.new("BodyVelocity")
	bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
	local launchDir = (root.CFrame.LookVector + Vector3.new(0, 0.3, 0)).Unit
	bv.Velocity = launchDir * PROJECTILE_SPEED
	bv.Parent = projectile

	SoundService.PlayLocal("HairsprayWhiz")

	-- Hit detection
	local hasLanded = false

	projectile.Touched:Connect(function(hit)
		if hasLanded then return end
		if hit:IsDescendantOf(char) then return end

		hasLanded = true
		bv:Destroy()
		flightParticle.Enabled = false
		projectile.Anchored = true

		local explosionPos = projectile.Position

		-- Explosion VFX (server fires to all via remote; client handles visuals)
		-- We fire a RemoteEvent so server-side hit detection runs there
		local HairsprayExplodeRemote = Remotes:FindFirstChild("HairsprayExplode") or Instance.new("RemoteEvent", Remotes)
		HairsprayExplodeRemote.Name = "HairsprayExplode"
		HairsprayExplodeRemote:FireServer(explosionPos, EXPLOSION_RADIUS)

		SoundService.PlayLocal("HairsprayExplode")

		Debris:AddItem(projectile, 0.2)
	end)

	Debris:AddItem(projectile, PROJECTILE_LIFETIME)

	-- Cooldown
	task.wait(COOLDOWN)
	debounce = false
end)

-- Server-side explosion handler (put this in a separate Script or ServerScriptService module)
-- File: HairsprayExplosionHandler (Script in ServerScriptService)
--[[
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))

local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local HairsprayExplode = Remotes:WaitForChild("HairsprayExplode")
local ShowstopperService -- lazy-loaded

local ExplosionVFX = Remotes:FindFirstChild("ShowExplosionVFX") or Instance.new("RemoteEvent", Remotes)
ExplosionVFX.Name = "ShowExplosionVFX"

local AbilityCooldownUpdate = Remotes:WaitForChild("AbilityCooldownUpdate")
AbilityCooldownUpdate.OnServerEvent:Connect(function(player, abilityName, duration)
	-- Forward to HUD controller
	local HUDUpdate = Remotes:FindFirstChild("HUDCooldownUpdate") or Instance.new("RemoteEvent", Remotes)
	HUDUpdate.Name = "HUDCooldownUpdate"
	HUDUpdate:FireClient(player, abilityName, duration)
end)

HairsprayExplode.OnServerEvent:Connect(function(player, explosionPos, radius)
	-- Anti-exploit: player must be within range of explosion
	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not root then return end
	if (root.Position - explosionPos).Magnitude > 80 then
		warn("[EXPLOIT] Hairspray explosion too far from player.")
		return
	end

	-- Fire VFX to all clients
	ExplosionVFX:FireAllClients(explosionPos)

	-- Apply slow to Critics in radius
	local hitAnyone = false
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Team and p.Team.Name == "Critics" then
			local pRoot = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
			local hum = p.Character and p.Character:FindFirstChildOfClass("Humanoid")
			if pRoot and hum and (pRoot.Position - explosionPos).Magnitude <= radius then
				if not hum:GetAttribute("IsSlowed") then
					hitAnyone = true
					hum:SetAttribute("IsSlowed", true)
					local originalSpeed = hum.WalkSpeed
					hum.WalkSpeed = originalSpeed * 0.5

					-- Camera shake for the critic
					local ShakeRemote = Remotes:FindFirstChild("CameraShake") or Instance.new("RemoteEvent", Remotes)
					ShakeRemote.Name = "CameraShake"
					ShakeRemote:FireClient(p)
					SoundService.FireToClient(p, "StunShake")

					task.delay(5, function()
						if hum then
							hum.WalkSpeed = originalSpeed
							hum:SetAttribute("IsSlowed", nil)
						end
					end)
				end
			end
		end
	end

	if hitAnyone and _G.ShowstopperService then
		_G.ShowstopperService.OnAbilityHit(player)
	end
end)
--]]
