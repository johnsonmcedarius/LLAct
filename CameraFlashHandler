-- CameraFlashHandler (Script in ServerScriptService)
-- FIXED: ServiceRegistry.Await replaces _G.AbilityImmunity / _G.ShowstopperService / _G.DailyLookbook

local Players             = game:GetService("Players")
local ReplicatedStorage   = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")

local ServiceRegistry    = require(ServerScriptService:WaitForChild("ServiceRegistry"))
local AbilityImmunity    = ServiceRegistry.Await("AbilityImmunity")
local ShowstopperService = ServiceRegistry.Await("ShowstopperService")

local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))
local Remotes      = ReplicatedStorage:WaitForChild("Remotes")

local function getRemote(name)
	local r = Remotes:FindFirstChild(name)
	if not r then r = Instance.new("RemoteEvent") r.Name = name r.Parent = Remotes end
	return r
end

local StunCriticRadius = getRemote("StunCriticRadius")
local BlindClient      = getRemote("BlindClient")
local PlayDazedAnim    = getRemote("PlayDazedAnim")

local DESIGNER_TEAM       = "Designers"
local CRITIC_TEAM         = "Critics"
local MAX_ALLOWED_RADIUS  = 25
local ORIGIN_TOLERANCE    = 10
local BASE_BLIND_DURATION = 4.0
local SERVER_COOLDOWN     = 6

local lastUsedFlash = {}

local function hasLineOfSight(fromPos, toPos, ignoreList)
	local dir = toPos - fromPos
	local rp  = RaycastParams.new()
	rp.FilterDescendantsInstances = ignoreList
	rp.FilterType = Enum.RaycastFilterType.Exclude
	return workspace:Raycast(fromPos, dir.Unit * dir.Magnitude, rp) == nil
end

StunCriticRadius.OnServerEvent:Connect(function(player, flashPos, radius, duration)
	if not (player.Team and player.Team.Name == DESIGNER_TEAM) then return end

	local now = os.clock()
	if now - (lastUsedFlash[player.UserId] or 0) < SERVER_COOLDOWN then
		warn("[EXPLOIT] " .. player.Name .. " CameraFlash before cooldown.")
		return
	end
	lastUsedFlash[player.UserId] = now

	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not root then return end
	if typeof(flashPos) ~= "Vector3" then return end
	if (root.Position - flashPos).Magnitude > ORIGIN_TOLERANCE then
		warn("[EXPLOIT] " .. player.Name .. " flash origin too far.")
		return
	end

	radius = math.min(radius or 18, MAX_ALLOWED_RADIUS)

	local hitAnyone = false

	for _, critic in ipairs(Players:GetPlayers()) do
		if not (critic.Team and critic.Team.Name == CRITIC_TEAM) then continue end

		local criticChar = critic.Character
		local criticRoot = criticChar and criticChar:FindFirstChild("HumanoidRootPart")
		if not criticRoot then continue end
		if (criticRoot.Position - flashPos).Magnitude > radius then continue end

		if not hasLineOfSight(flashPos, criticRoot.Position, {player.Character, criticChar}) then
			print("[CAMERA] " .. critic.Name .. " blocked by wall.")
			continue
		end

		local multiplier = AbilityImmunity.TryHit(critic)
		if not multiplier then continue end

		hitAnyone = true
		local blindDuration = BASE_BLIND_DURATION * multiplier

		BlindClient:FireClient(critic, blindDuration)
		PlayDazedAnim:FireClient(critic, blindDuration)
		SoundService.FireToClient(critic, "CameraFlash")
		SoundService.FireToAll("AbilityHit", criticRoot.Position)

		print("[CAMERA] " .. critic.Name .. " blinded for "
			.. string.format("%.1f", blindDuration) .. "s (x" .. string.format("%.2f", multiplier) .. ")")
	end

	if not hitAnyone then
		SoundService.FireToClient(player, "AbilityMiss")
	end

	if hitAnyone then
		ShowstopperService.OnAbilityHit(player)
		local lb = ServiceRegistry.Get("DailyLookbook")
		if lb then lb.AddProgress(player, "Stuns", 1) end
	end
end)

Players.PlayerRemoving:Connect(function(p)
	lastUsedFlash[p.UserId] = nil
end)
