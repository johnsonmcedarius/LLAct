-- CameraFlashHandler (Script in ServerScriptService)
-- Phase 2.5 fix: adds line-of-sight raycast between designer and each critic
-- before applying the blind. Prevents blinding through walls.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))

local Remotes = ReplicatedStorage:WaitForChild("Remotes")

local StunCriticRadius = Remotes:WaitForChild("StunCriticRadius")

local BlindClient = Remotes:FindFirstChild("BlindClient") or Instance.new("RemoteEvent", Remotes)
BlindClient.Name = "BlindClient"

local PlayDazedAnim = Remotes:FindFirstChild("PlayDazedAnim") or Instance.new("RemoteEvent", Remotes)
PlayDazedAnim.Name = "PlayDazedAnim"

local DESIGNER_TEAM      = "Designers"
local CRITIC_TEAM        = "Critics"
local MAX_ALLOWED_RADIUS = 25
local ORIGIN_TOLERANCE   = 10 -- how far flash origin can be from designer

-------------------------------------------------
-- Line-of-sight check between two positions
-------------------------------------------------
local function hasLineOfSight(fromPos, toPos, ignoreList)
	local direction = toPos - fromPos
	local distance  = direction.Magnitude

	local rayParams = RaycastParams.new()
	rayParams.FilterDescendantsInstances = ignoreList
	rayParams.FilterType = Enum.RaycastFilterType.Exclude

	local result = workspace:Raycast(fromPos, direction.Unit * distance, rayParams)

	-- If no hit, or hit is inside the target character, line of sight is clear
	return result == nil
end

-------------------------------------------------
-- Flash handler
-------------------------------------------------
StunCriticRadius.OnServerEvent:Connect(function(player, flashPos, radius, duration)
	-- Validate: must be a Designer
	if not (player.Team and player.Team.Name == DESIGNER_TEAM) then return end

	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not root then return end

	-- Anti-exploit: flash origin must be near the player
	if (root.Position - flashPos).Magnitude > ORIGIN_TOLERANCE then
		warn("[EXPLOIT] " .. player.Name .. " camera flash origin too far.")
		return
	end

	radius = math.min(radius, MAX_ALLOWED_RADIUS)

	local hitAnyone = false

	for _, critic in ipairs(Players:GetPlayers()) do
		if not (critic.Team and critic.Team.Name == CRITIC_TEAM) then continue end

		local criticChar = critic.Character
		local criticRoot = criticChar and criticChar:FindFirstChild("HumanoidRootPart")
		if not criticRoot then continue end

		-- Distance check
		if (criticRoot.Position - flashPos).Magnitude > radius then continue end

		-- Line-of-sight raycast (ignore designer and critic characters)
		local ignoreList = {player.Character, criticChar}
		local los = hasLineOfSight(flashPos, criticRoot.Position, ignoreList)

		if not los then
			print("[CAMERA] " .. critic.Name .. " is behind a wall. No blind.")
			continue
		end

		hitAnyone = true

		BlindClient:FireClient(critic, duration)
		PlayDazedAnim:FireClient(critic, duration)
		SoundService.FireToClient(critic, "CameraFlash")
		SoundService.FireToAll("AbilityHit", criticRoot.Position)

		print("[CAMERA] " .. critic.Name .. " blinded for " .. duration .. "s (LOS confirmed).")
	end

	if not hitAnyone then
		SoundService.FireToClient(player, "AbilityMiss")
	end

	if hitAnyone and _G.ShowstopperService then
		_G.ShowstopperService.OnAbilityHit(player)
	end
end)
