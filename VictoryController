local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

-- Direct requires from ReplicatedStorage (The proper way for Clients)
local VFXModule = require(ReplicatedStorage:WaitForChild("VFXModule"))
local Remotes = ReplicatedStorage:WaitForChild("Remotes")

local Player = Players.LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")

-- UI References
local VictoryGui = PlayerGui:WaitForChild("VictoryGui")
local VSIntroGui = PlayerGui:WaitForChild("VSIntroGui")
local StatsGui = PlayerGui:WaitForChild("EndStatsGui")

-- Configuration
local ANIM_CRITIC_WIN = "rbxassetid://YOUR_CRITIC_ANIM_ID"
local ANIM_DESIGNER_WIN = "rbxassetid://YOUR_DESIGNER_ANIM_ID"

-------------------------------------------------
-- Viewport Helper: Dressing the Stage
-------------------------------------------------
local function SetupViewportCharacter(targetPlayer, container, animationId)
	container:ClearAllChildren()

	local character = targetPlayer.Character or targetPlayer.CharacterAdded:Wait()
	character.Archivable = true
	local clone = character:Clone()
	character.Archivable = false

	local viewport = Instance.new("ViewportFrame")
	viewport.Size = UDim2.fromScale(1, 1)
	viewport.BackgroundTransparency = 1
	viewport.Parent = container

	local worldModel = Instance.new("WorldModel")
	worldModel.Parent = viewport
	clone.Parent = worldModel

	local camera = Instance.new("Camera")
	viewport.CurrentCamera = camera
	camera.Parent = viewport

	-- Camera framing for that high-fashion look
	local hrp = clone:WaitForChild("HumanoidRootPart")
	camera.CFrame = CFrame.new(hrp.Position + hrp.CFrame.LookVector * 5 + Vector3.new(0, 1.5, 0), hrp.Position)

	-- Play Victory Pose
	local humanoid = clone:WaitForChild("Humanoid")
	local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)
	local anim = Instance.new("Animation")
	anim.AnimationId = animationId

	local track = animator:LoadAnimation(anim)
	track.Looped = true
	track:Play()

	return viewport
end

-------------------------------------------------
-- Event Listeners
-------------------------------------------------

-- ── Round Started: The VS Intro ──
Remotes:WaitForChild("RoundStarted").OnClientEvent:Connect(function(data)
	VSIntroGui.Enabled = true

	-- Note: You can expand this to fill the VS slots with data.Critics and data.Designers
	print("[INTRO] The show is starting. Lock in.")

	task.delay(4, function()
		VSIntroGui.Enabled = false
	end)
end)

-- ── Round Ended: The Big Reveal ──
Remotes:WaitForChild("RoundEnded").OnClientEvent:Connect(function(victoryData)
	local winner = victoryData.WinnerTeam
	VictoryGui.Enabled = true

	-- 1. Trigger Global VFX (Zero-latency vibes)
	if winner == "Designers" then
		VFXModule.PlayGlobalCelebration("Confetti")
		VictoryGui.Title.Text = "THE COLLECTION IS A HIT!"
	else
		VFXModule.PlayGlobalCelebration("CancelStatic")
		VictoryGui.Title.Text = "THE CRITICS SHUT IT DOWN!"
	end

	-- 2. Populate Winner Slots
	if winner == "Critics" then
		for i, criticPlayer in ipairs(victoryData.Critics or {}) do
			local slot = VictoryGui.Content:FindFirstChild("CriticSlot" .. i)
			if slot and criticPlayer then
				SetupViewportCharacter(criticPlayer, slot, ANIM_CRITIC_WIN)
			end
		end
	elseif winner == "Designers" then
		-- Designers usually win as a team/top performers
		for i, designerData in ipairs(victoryData.TopDesigners or {}) do
			local slot = VictoryGui.Content:FindFirstChild("DesignerSlot" .. i)
			if slot and designerData.Player then
				SetupViewportCharacter(designerData.Player, slot, ANIM_DESIGNER_WIN)
			end
		end
	end

	-- 3. Transition to Stats
	task.delay(8, function()
		VictoryGui.Enabled = false
		StatsGui.Enabled = true
	end)
end)

print("[CLIENT] VictoryController initialized. May 15th ready.")
