-- HairsprayExplosionHandler (Script in ServerScriptService)
-- Phase 4 fix: server-side lastUsed cooldown, name-before-parent remotes.

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))
local Remotes      = ReplicatedStorage:WaitForChild("Remotes")

local function getRemote(name)
	local r = Remotes:FindFirstChild(name)
	if not r then
		r        = Instance.new("RemoteEvent")  -- name BEFORE parent
		r.Name   = name
		r.Parent = Remotes
	end
	return r
end

local HairsprayExplode      = getRemote("HairsprayExplode")
local ExplosionVFX          = getRemote("ShowExplosionVFX")
local HUDCooldownUpdate     = getRemote("HUDCooldownUpdate")
local AbilityCooldownUpdate = getRemote("AbilityCooldownUpdate")
local CameraShake           = getRemote("CameraShake")

local SERVER_COOLDOWN  = 8    -- Must match client COOLDOWN
local MAX_ORIGIN_DIST  = 80
local MAX_RADIUS       = 25
local DESIGNER_TEAM    = "Designers"
local CRITIC_TEAM      = "Critics"

-- Server-side cooldown tables
local lastUsedHairspray  = {}   -- [userId] = os.clock()
local lastUsedCooldownFwd = {}  -- [userId] = os.clock() for AbilityCooldownUpdate

-- Forward ability cooldown signals to HUD (with server-side rate limit)
AbilityCooldownUpdate.OnServerEvent:Connect(function(player, abilityName, duration)
	local now = os.clock()
	local key = player.UserId .. abilityName
	if lastUsedCooldownFwd[key] and now - lastUsedCooldownFwd[key] < 1 then return end
	lastUsedCooldownFwd[key] = now

	if type(abilityName) ~= "string" then return end
	if type(duration) ~= "number" or duration < 0 or duration > 60 then return end

	HUDCooldownUpdate:FireClient(player, abilityName, duration)
end)

-- Explosion handler
HairsprayExplode.OnServerEvent:Connect(function(player, explosionPos, radius)
	if not (player.Team and player.Team.Name == DESIGNER_TEAM) then return end

	-- Server-side cooldown
	local now = os.clock()
	if now - (lastUsedHairspray[player.UserId] or 0) < SERVER_COOLDOWN then
		warn("[EXPLOIT] " .. player.Name .. " fired HairsprayExplode before cooldown.")
		return
	end
	lastUsedHairspray[player.UserId] = now

	-- Validate types
	if typeof(explosionPos) ~= "Vector3" then return end
	if type(radius) ~= "number" then return end

	-- Distance check
	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not root then return end
	if (root.Position - explosionPos).Magnitude > MAX_ORIGIN_DIST then
		warn("[EXPLOIT] " .. player.Name .. " explosion origin too far.")
		return
	end

	radius = math.min(radius, MAX_RADIUS)

	ExplosionVFX:FireAllClients(explosionPos)
	SoundService.FireToAll("HairsprayExplode", explosionPos)

	local hitAnyone = false

	for _, p in ipairs(Players:GetPlayers()) do
		if not (p.Team and p.Team.Name == CRITIC_TEAM) then continue end

		local pRoot = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
		local hum   = p.Character and p.Character:FindFirstChildOfClass("Humanoid")
		if not pRoot or not hum then continue end

		if (pRoot.Position - explosionPos).Magnitude > radius then continue end

		if not hum:GetAttribute("IsSlowed") then
			hitAnyone = true
			hum:SetAttribute("IsSlowed", true)

			local originalSpeed = hum.WalkSpeed
			hum.WalkSpeed = originalSpeed * 0.5

			CameraShake:FireClient(p)
			SoundService.FireToClient(p, "StunShake")
			SoundService.FireToAll("AbilityHit", pRoot.Position)

			task.delay(5, function()
				if hum then
					hum.WalkSpeed = originalSpeed
					hum:SetAttribute("IsSlowed", nil)
				end
			end)
		end
	end

	if not hitAnyone then
		SoundService.FireToClient(player, "AbilityMiss")
	end

	if hitAnyone and _G.ShowstopperService then
		_G.ShowstopperService.OnAbilityHit(player)
	end
end)

Players.PlayerRemoving:Connect(function(p)
	lastUsedHairspray[p.UserId] = nil
end)
