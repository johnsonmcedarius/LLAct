local CollectionService = game:GetService("CollectionService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer

local function updatePrompts()
	local teamName = (player.Team and player.Team.Name) or ""
	local isDesigner = (teamName == "Designers")
	local isCritic = (teamName == "Critics")

	-- 1. Handle Designer Prompts (Passing, Unfreezing, Collecting) [cite: 10, 24, 42]
	for _, obj in ipairs(CollectionService:GetTagged("DesignerPrompt")) do
		-- Safety check: Find the prompt even if you tagged the Part by mistake
		local prompt = obj:IsA("ProximityPrompt") and obj or obj:FindFirstChildOfClass("ProximityPrompt")

		if prompt then
			if isDesigner then
				-- Special logic for Passing: Only show if holding fabric [cite: 17, 24]
				if prompt.ActionText == "Give Fabric" then
					local hasFabric = player.Backpack:FindFirstChild("FBRoll") or (player.Character and player.Character:FindFirstChild("FBRoll"))
					prompt.Enabled = (hasFabric ~= nil)
				else
					-- Unfreeze or Rack prompt
					prompt.Enabled = true
				end
			else
				-- Hide Designer actions from Critics
				prompt.Enabled = false
			end
		end
	end

	-- 2. Handle Critic Prompts (Sabotage)
	for _, obj in ipairs(CollectionService:GetTagged("CriticPrompt")) do
		local prompt = obj:IsA("ProximityPrompt") and obj or obj:FindFirstChildOfClass("ProximityPrompt")
		if prompt then
			prompt.Enabled = isCritic
		end
	end
end

-- Refresh whenever something changes in the inventory (Backpack OR Character) 
local function hookCharacter(char)
	char.ChildAdded:Connect(updatePrompts)
	char.ChildRemoved:Connect(updatePrompts)
	updatePrompts()
end

player.CharacterAdded:Connect(hookCharacter)
if player.Character then hookCharacter(player.Character) end

player.Backpack.ChildAdded:Connect(updatePrompts)
player.Backpack.ChildRemoved:Connect(updatePrompts)

-- Team & Tag listeners
player:GetPropertyChangedSignal("Team"):Connect(updatePrompts)
CollectionService:GetInstanceAddedSignal("DesignerPrompt"):Connect(updatePrompts)
CollectionService:GetInstanceAddedSignal("CriticPrompt"):Connect(updatePrompts)

-- Initial run
updatePrompts()
