-- FabricManager (Script in ServerScriptService)
-- FIXED: _G replaced with ServiceRegistry.Await / .Get
-- Round reset uses RoundEvents.

local CollectionService   = game:GetService("CollectionService")
local ReplicatedStorage   = game:GetService("ReplicatedStorage")
local Players             = game:GetService("Players")
local TweenService        = game:GetService("TweenService")
local Debris              = game:GetService("Debris")
local ServerScriptService = game:GetService("ServerScriptService")

local ServiceRegistry = require(ServerScriptService:WaitForChild("ServiceRegistry"))
local RoundEvents     = require(ServerScriptService:WaitForChild("RoundEvents"))

-- Await hard dependencies
local ShowstopperService = ServiceRegistry.Await("ShowstopperService")
local RewardTracker      = ServiceRegistry.Await("RewardTracker")

local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))

local Remotes = ReplicatedStorage:WaitForChild("Remotes")

local function getRemote(name)
	local r = Remotes:FindFirstChild(name)
	if not r then r = Instance.new("RemoteEvent") r.Name = name r.Parent = Remotes end
	return r
end

local NotifyCritics        = getRemote("NotifyCritics")
local UpdateFabricUI       = getRemote("UpdateFabricUI")
local TrendTrackerActivate = getRemote("TrendTrackerActivate")
local PlayProximitySound   = getRemote("PlayProximitySound")
local ShowExitWaypoint     = getRemote("ShowExitWaypoint")
local ShowRewardPopup      = getRemote("ShowRewardPopup")
local DepositVFX           = getRemote("DepositVFX")
local SabotagePing         = getRemote("SabotagePing")
local RackStateChanged     = getRemote("RackStateChanged")
local RackPickupVFX        = getRemote("RackPickupVFX")

local MAX_INTERACTION_DISTANCE = 30
local RACK_COOLDOWN            = 5
local BIN_HITBOX_SIZE          = Vector3.new(10, 8, 10)
local SABOTAGE_HOLD_DURATION   = 3.5
local SABOTAGED_PICKUP_HOLD    = 3.0
local NORMAL_PICKUP_HOLD       = 0
local TANGLE_DURATION          = 60
local SABOTAGE_RULE_OF_TWO     = 2
local SABOTAGE_COOLDOWN        = 30

local Config = {
	TotalFabricNeeded = 5,
	ExitDoorName      = "RunwayExit",
	CriticTeamName    = "Critics",
	DesignerTeamName  = "Designers",
}

local globalFabricCount      = 0
local lastFiredPercentage    = -1
local trendTrackerFired      = false
local criticSabotageQueue    = {}
local criticSabotageCooldown = {}
local tangleTimers           = {}

local function setRackState(rack, sabotaged)
	local regular  = rack:FindFirstChild("RegularState")
	local sabState = rack:FindFirstChild("SabotagedState")

	if regular then
		for _, p in ipairs(regular:GetDescendants()) do
			if p:IsA("BasePart") then
				p.Transparency = sabotaged and 1 or 0
				p.CanCollide   = not sabotaged
			end
		end
	end
	if sabState then
		for _, p in ipairs(sabState:GetDescendants()) do
			if p:IsA("BasePart") then
				p.Transparency = sabotaged and 0 or 1
				p.CanCollide   = sabotaged
			end
		end
	end

	rack:SetAttribute("IsSabotaged", sabotaged)
	RackStateChanged:FireAllClients(rack, sabotaged)
end

local function alertCritics(rack, isSabotageAlert)
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Team and p.Team.Name == Config.CriticTeamName then
			if isSabotageAlert then
				SabotagePing:FireClient(p, rack)
			else
				NotifyCritics:FireClient(p, rack)
			end
		end
	end
end

local function openRunwayExit()
	local exitDoor = workspace:FindFirstChild(Config.ExitDoorName)
	if exitDoor then
		exitDoor:SetAttribute("IsOpen", true)
		exitDoor.Transparency = 0.5
		exitDoor.CanCollide   = false
		local exitBase = exitDoor:IsA("BasePart") and exitDoor or exitDoor:FindFirstChildWhichIsA("BasePart")
		if exitBase then ShowExitWaypoint:FireAllClients(exitBase.Position) end
	else
		warn("[FABRIC] Runway Exit not found: " .. Config.ExitDoorName)
	end
end

local function addGlobalFabric(amount)
	globalFabricCount += amount
	local pct = math.clamp(math.floor((globalFabricCount / Config.TotalFabricNeeded) * 100), 0, 100)

	if pct ~= lastFiredPercentage then
		UpdateFabricUI:FireAllClients(pct)
		lastFiredPercentage = pct
	end

	if pct >= 75 and not trendTrackerFired then
		trendTrackerFired = true
		local w75 = getRemote("Show75Warning")
		for _, p in ipairs(Players:GetPlayers()) do
			if p.Team and p.Team.Name == Config.DesignerTeamName then
				w75:FireClient(p)
			end
			if p.Team and p.Team.Name == Config.CriticTeamName then
				TrendTrackerActivate:FireClient(p, 20)
			end
		end
		SoundService.FireToAll("PaparazziStorm", Vector3.zero)
	end

	if globalFabricCount >= Config.TotalFabricNeeded then
		openRunwayExit()
	end
end

local function giveFabricTool(player)
	local assets  = ReplicatedStorage:FindFirstChild("Assets")
	local fbAsset = assets and assets:FindFirstChild("FBRoll")
	if fbAsset then
		fbAsset:Clone().Parent = player.Backpack
	else
		warn("[FABRIC] FBRoll missing from ReplicatedStorage.Assets!")
	end
end

local function playerHasFabric(player)
	return player.Backpack:FindFirstChild("FBRoll")
		or (player.Character and player.Character:FindFirstChild("FBRoll"))
end

local function recordSabotage(critic, rack)
	local uid   = critic.UserId
	local queue = criticSabotageQueue[uid] or {}
	criticSabotageQueue[uid] = queue

	if #queue >= SABOTAGE_RULE_OF_TWO then
		local oldest = table.remove(queue, 1)
		if oldest and oldest.Parent then
			setRackState(oldest, false)
			local dp = oldest:FindFirstChild("DesignerPickup")
			if dp then dp.HoldDuration = NORMAL_PICKUP_HOLD dp.ActionText = "Collect Fabric" end
			if tangleTimers[oldest] then task.cancel(tangleTimers[oldest]) tangleTimers[oldest] = nil end
		end
	end
	table.insert(queue, rack)
end

local function unsabotageRack(rack)
	if not rack or not rack.Parent then return end
	setRackState(rack, false)
	local dp = rack:FindFirstChild("DesignerPickup")
	if dp then dp.HoldDuration = NORMAL_PICKUP_HOLD dp.ActionText = "Collect Fabric" dp.Enabled = true end
	local cp = rack:FindFirstChild("CriticSabotage")
	if cp then cp.Enabled = true end
	tangleTimers[rack] = nil

	for _, queue in pairs(criticSabotageQueue) do
		for i, r in ipairs(queue) do
			if r == rack then table.remove(queue, i) break end
		end
	end
end

local function setupFabricRack(rack)
	for _, child in ipairs(rack:GetDescendants()) do
		if child:IsA("ProximityPrompt") then child:Destroy() end
	end

	rack:SetAttribute("IsOnCooldown", false)
	rack:SetAttribute("IsSabotaged",  false)
	setRackState(rack, false)

	local dp        = Instance.new("ProximityPrompt")
	dp.Name         = "DesignerPickup"
	dp.ActionText   = "Collect Fabric"
	dp.ObjectText   = "Fabric Rack"
	dp.HoldDuration = NORMAL_PICKUP_HOLD
	dp.RequiresLineOfSight   = false
	dp.MaxActivationDistance = 8
	dp.Parent       = rack

	local cp        = Instance.new("ProximityPrompt")
	cp.Name         = "CriticSabotage"
	cp.ActionText   = "Sabotage Rack"
	cp.ObjectText   = "Fabric Rack"
	cp.HoldDuration = SABOTAGE_HOLD_DURATION
	cp.RequiresLineOfSight   = false
	cp.MaxActivationDistance = 8
	cp.Parent       = rack

	dp.Triggered:Connect(function(player)
		if not (player.Team and player.Team.Name == Config.DesignerTeamName) then return end
		if rack:GetAttribute("IsOnCooldown") then return end
		if playerHasFabric(player) then return end

		local root    = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		local rackBase = rack:IsA("BasePart") and rack or rack:FindFirstChildWhichIsA("BasePart")
		if root and rackBase and (root.Position - rackBase.Position).Magnitude > MAX_INTERACTION_DISTANCE then
			warn("[EXPLOIT] " .. player.Name .. " rack grab too far.")
			return
		end

		local wasSabotaged = rack:GetAttribute("IsSabotaged")
		print("[FABRIC] " .. player.Name .. " collected from rack (sabotaged=" .. tostring(wasSabotaged) .. ")")

		giveFabricTool(player)

		local rackPos = rackBase and rackBase.Position or Vector3.zero
		RackPickupVFX:FireAllClients(rackPos)
		SoundService.FireToAll("FabricPickup", rackPos)
		PlayProximitySound:FireAllClients(rack, "SnipZip")

		if wasSabotaged then
			alertCritics(rack, true)
			if tangleTimers[rack] then task.cancel(tangleTimers[rack]) tangleTimers[rack] = nil end
		else
			alertCritics(rack, false)
		end

		RewardTracker.OnFabricCollect(player)

		rack:SetAttribute("IsOnCooldown", true)
		rack:SetAttribute("IsSabotaged",  false)
		dp.Enabled = false
		cp.Enabled = false
		dp.HoldDuration = NORMAL_PICKUP_HOLD
		dp.ActionText   = "Collect Fabric"

		setRackState(rack, false)

		local regularFolder = rack:FindFirstChild("RegularState")
		if regularFolder then
			for _, p in ipairs(regularFolder:GetDescendants()) do
				if p:IsA("BasePart") then p.Transparency = 0.7 end
			end
		end

		task.delay(RACK_COOLDOWN, function()
			if not rack or not rack.Parent then return end
			rack:SetAttribute("IsOnCooldown", false)
			dp.Enabled = true
			cp.Enabled = true
			if regularFolder then
				for _, p in ipairs(regularFolder:GetDescendants()) do
					if p:IsA("BasePart") then p.Transparency = 0 end
				end
			end
			setRackState(rack, false)
			print("[FABRIC] Rack refreshed.")
		end)
	end)

	cp.Triggered:Connect(function(critic)
		if not (critic.Team and critic.Team.Name == Config.CriticTeamName) then return end
		if rack:GetAttribute("IsOnCooldown") then return end
		if rack:GetAttribute("IsSabotaged") then return end

		local now        = os.clock()
		local coolExpiry = criticSabotageCooldown[critic.UserId] or 0
		if now < coolExpiry then print("[SABOTAGE] " .. critic.Name .. " on cooldown.") return end

		local criticRoot = critic.Character and critic.Character:FindFirstChild("HumanoidRootPart")
		local rackBase   = rack:IsA("BasePart") and rack or rack:FindFirstChildWhichIsA("BasePart")
		if criticRoot and rackBase and (criticRoot.Position - rackBase.Position).Magnitude > MAX_INTERACTION_DISTANCE then
			warn("[EXPLOIT] " .. critic.Name .. " sabotage too far.")
			return
		end

		print("[SABOTAGE] " .. critic.Name .. " sabotaged rack!")
		criticSabotageCooldown[critic.UserId] = now + SABOTAGE_COOLDOWN
		recordSabotage(critic, rack)
		setRackState(rack, true)

		dp.HoldDuration = SABOTAGED_PICKUP_HOLD
		dp.ActionText   = "Collect Fabric (TANGLED)"

		RewardTracker.OnSabotage(critic)

		local rackPos = rackBase and rackBase.Position or Vector3.zero
		SoundService.FireToAll("HairsprayHiss", rackPos)

		if tangleTimers[rack] then task.cancel(tangleTimers[rack]) end
		tangleTimers[rack] = task.delay(TANGLE_DURATION, function()
			unsabotageRack(rack)
			print("[SABOTAGE] Tangle expired on rack.")
		end)
	end)
end

local function setupFabricBin(bin)
	for _, child in ipairs(bin:GetDescendants()) do
		if child:IsA("ProximityPrompt") then child:Destroy() end
	end

	local hitbox = bin:FindFirstChild("DepositHitbox")
	if not hitbox then
		hitbox              = Instance.new("Part")
		hitbox.Name         = "DepositHitbox"
		hitbox.Size         = BIN_HITBOX_SIZE
		hitbox.Transparency = 1
		hitbox.CanCollide   = false
		hitbox.Anchored     = true
		local binBase = bin:IsA("BasePart") and bin or bin:FindFirstChildWhichIsA("BasePart")
		if binBase then hitbox.CFrame = binBase.CFrame end
		hitbox.Parent = bin
	else
		hitbox.Size = BIN_HITBOX_SIZE
	end

	local depositing = {}

	hitbox.Touched:Connect(function(hit)
		local character = hit.Parent
		local player    = Players:GetPlayerFromCharacter(character)
		if not player then return end
		if not (player.Team and player.Team.Name == Config.DesignerTeamName) then return end
		if depositing[player.UserId] then return end

		local fabricTool = character:FindFirstChild("FBRoll") or player.Backpack:FindFirstChild("FBRoll")
		if not fabricTool then return end

		local root    = character:FindFirstChild("HumanoidRootPart")
		local binBase = bin:IsA("BasePart") and bin or bin:FindFirstChildWhichIsA("BasePart")
		if root and binBase and (root.Position - binBase.Position).Magnitude > MAX_INTERACTION_DISTANCE then
			warn("[EXPLOIT] " .. player.Name .. " deposit too far.")
			return
		end

		depositing[player.UserId] = true
		local depositPos = binBase and binBase.Position or Vector3.zero

		fabricTool:Destroy()
		addGlobalFabric(1)

		SoundService.FireToAll("FabricDunk", depositPos)
		DepositVFX:FireAllClients(depositPos)

		ShowstopperService.OnFabricDunk(player)
		RewardTracker.OnFabricCollect(player)

		ShowRewardPopup:FireClient(player, "+25 XP", "+5 Coins")

		task.delay(0.5, function() depositing[player.UserId] = nil end)
	end)
end

local function resetAll()
	globalFabricCount   = 0
	lastFiredPercentage = -1
	trendTrackerFired   = false
	UpdateFabricUI:FireAllClients(0)

	for rack, handle in pairs(tangleTimers) do
		task.cancel(handle)
	end
	tangleTimers = {}

	for _, rack in ipairs(CollectionService:GetTagged("FabricRacks")) do
		if rack and rack.Parent then
			rack:SetAttribute("IsOnCooldown", false)
			rack:SetAttribute("IsSabotaged",  false)
			setRackState(rack, false)
			local dp = rack:FindFirstChild("DesignerPickup")
			if dp then dp.HoldDuration = NORMAL_PICKUP_HOLD dp.ActionText = "Collect Fabric" dp.Enabled = true end
			local cp = rack:FindFirstChild("CriticSabotage")
			if cp then cp.Enabled = true end
			local rf = rack:FindFirstChild("RegularState")
			if rf then for _, p in ipairs(rf:GetDescendants()) do if p:IsA("BasePart") then p.Transparency = 0 end end end
		end
	end

	criticSabotageQueue    = {}
	criticSabotageCooldown = {}
end

RoundEvents.Intermission.Event:Connect(resetAll)

Players.PlayerRemoving:Connect(function(p)
	criticSabotageCooldown[p.UserId] = nil
end)

for _, r in ipairs(CollectionService:GetTagged("FabricRacks")) do setupFabricRack(r) end
for _, b in ipairs(CollectionService:GetTagged("FabricBins"))  do setupFabricBin(b)  end
CollectionService:GetInstanceAddedSignal("FabricRacks"):Connect(setupFabricRack)
CollectionService:GetInstanceAddedSignal("FabricBins"):Connect(setupFabricBin)
