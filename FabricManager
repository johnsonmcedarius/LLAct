-- FabricManager (Script in ServerScriptService)
-- Deposit sound + VFX, 75% paparazzi storm, waypoint marker on exit open,
-- showstopper charge wiring, intercept-pass detection.

local CollectionService = game:GetService("CollectionService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local Teams = game:GetService("Teams")
local Debris = game:GetService("Debris")

local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))

local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local NotifyCritics   = Remotes:WaitForChild("NotifyCritics")
local UpdateFabricUI  = Remotes:WaitForChild("UpdateFabricUI")

local TrendTrackerActivate = Remotes:FindFirstChild("TrendTrackerActivate") or Instance.new("RemoteEvent", Remotes)
TrendTrackerActivate.Name = "TrendTrackerActivate"

local PlayProximitySound = Remotes:FindFirstChild("PlayProximitySound") or Instance.new("RemoteEvent", Remotes)
PlayProximitySound.Name = "PlayProximitySound"

local ShowExitWaypoint = Remotes:FindFirstChild("ShowExitWaypoint") or Instance.new("RemoteEvent", Remotes)
ShowExitWaypoint.Name = "ShowExitWaypoint"

local ShowRewardPopup = Remotes:FindFirstChild("ShowRewardPopup") or Instance.new("RemoteEvent", Remotes)
ShowRewardPopup.Name = "ShowRewardPopup"

local PlaySound = Remotes:FindFirstChild("PlaySound") or Instance.new("RemoteEvent", Remotes)
PlaySound.Name = "PlaySound"

local DepositVFX = Remotes:FindFirstChild("DepositVFX") or Instance.new("RemoteEvent", Remotes)
DepositVFX.Name = "DepositVFX"

local StatusValues = ReplicatedStorage:WaitForChild("StatusValues")
local StatusText = StatusValues:WaitForChild("StatusText")

local MAX_INTERACTION_DISTANCE = 30
local RACK_COOLDOWN = 5
local BIN_HITBOX_SIZE = Vector3.new(10, 8, 10)

local Config = {
	TotalFabricNeeded = 5,
	ExitDoorName = "RunwayExit",
	CriticTeamName = "Critics",
	DesignerTeamName = "Designers",
}

local globalFabricCount = 0
local lastFiredPercentage = -1
local trendTrackerFired = false

-------------------------------------------------
-- Helpers
-------------------------------------------------

local function alertCritics(rack)
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Team and p.Team.Name == Config.CriticTeamName then
			NotifyCritics:FireClient(p, rack)
		end
	end
end

local function openRunwayExit()
	print("[FABRIC] Collection complete. Opening Runway Exit.")
	local exitDoor = workspace:FindFirstChild(Config.ExitDoorName)
	if exitDoor then
		exitDoor:SetAttribute("IsOpen", true)
		exitDoor.Transparency = 0.5
		exitDoor.CanCollide = false

		-- Tell all clients to show the exit waypoint marker
		local exitPos = exitDoor:IsA("BasePart") and exitDoor.Position
			or (exitDoor:FindFirstChildWhichIsA("BasePart") and exitDoor:FindFirstChildWhichIsA("BasePart").Position)
		if exitPos then
			ShowExitWaypoint:FireAllClients(exitPos)
		end
	else
		warn("[FABRIC] Runway Exit not found: " .. Config.ExitDoorName)
	end
end

local function addGlobalFabric(amount, depositor)
	globalFabricCount += amount
	local percentage = math.clamp(math.floor((globalFabricCount / Config.TotalFabricNeeded) * 100), 0, 100)

	if percentage ~= lastFiredPercentage then
		print("[FABRIC] Progress: " .. percentage .. "%")
		UpdateFabricUI:FireAllClients(percentage)
		lastFiredPercentage = percentage
	end

	-- 75% Trend Tracker
	if percentage >= 75 and not trendTrackerFired then
		trendTrackerFired = true
		print("[FABRIC] 75% reached. Trend Tracker activating for Critics.")

		-- Warn Designers
		for _, p in ipairs(Players:GetPlayers()) do
			if p.Team and p.Team.Name == Config.DesignerTeamName then
				Remotes:FindFirstChild("Show75Warning") and Remotes.Show75Warning:FireClient(p)
			end
		end

		-- Alert + aura for Critics
		for _, p in ipairs(Players:GetPlayers()) do
			if p.Team and p.Team.Name == Config.CriticTeamName then
				TrendTrackerActivate:FireClient(p, 20)
			end
		end

		-- Paparazzi storm sound to all
		SoundService.FireToAll("PaparazziStorm", Vector3.zero)
	end

	if globalFabricCount >= Config.TotalFabricNeeded then
		openRunwayExit()
	end
end

local function giveFabricTool(player)
	local fbToolAsset = ReplicatedStorage:FindFirstChild("Assets") and ReplicatedStorage.Assets:FindFirstChild("FBRoll")
	if fbToolAsset then
		fbToolAsset:Clone().Parent = player.Backpack
	else
		warn("[FABRIC] FBRoll missing from ReplicatedStorage.Assets!")
	end
end

local function playerHasFabric(player)
	return player.Backpack:FindFirstChild("FBRoll")
		or (player.Character and player.Character:FindFirstChild("FBRoll"))
end

-------------------------------------------------
-- Fabric Rack Setup (tag: FabricRacks)
-------------------------------------------------
local function setupFabricRack(rack)
	for _, child in ipairs(rack:GetDescendants()) do
		if child:IsA("ProximityPrompt") then child:Destroy() end
	end

	rack:SetAttribute("IsOnCooldown", false)

	local prompt = Instance.new("ProximityPrompt")
	prompt.ActionText = "Collect Fabric"
	prompt.ObjectText = "Fabric Rack"
	prompt.HoldDuration = 0
	prompt.RequiresLineOfSight = false
	prompt.MaxActivationDistance = 8
	prompt.Parent = rack

	prompt.Triggered:Connect(function(player)
		if not (player.Team and player.Team.Name == Config.DesignerTeamName) then return end
		if rack:GetAttribute("IsOnCooldown") then return end
		if playerHasFabric(player) then return end

		local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		local rackPart = rack:IsA("BasePart") and rack or rack:FindFirstChildWhichIsA("BasePart")
		if root and rackPart and (root.Position - rackPart.Position).Magnitude > MAX_INTERACTION_DISTANCE then
			warn("[EXPLOIT] " .. player.Name .. " distance exploit on rack.")
			return
		end

		print("[FABRIC] " .. player.Name .. " grabbed from rack.")
		giveFabricTool(player)
		alertCritics(rack)
		PlayProximitySound:FireAllClients(rack, "SnipZip")
		SoundService.FireToAll("FabricPickup", rackPart and rackPart.Position or Vector3.zero)

		-- Rack cooldown + transparency
		rack:SetAttribute("IsOnCooldown", true)
		prompt.Enabled = false
		local rackBase = rack:IsA("BasePart") and rack or rack:FindFirstChildWhichIsA("BasePart")
		if rackBase then rackBase.Transparency = 0.7 end

		task.delay(RACK_COOLDOWN, function()
			if not rack or not rack.Parent then return end
			rack:SetAttribute("IsOnCooldown", false)
			prompt.Enabled = true
			if rackBase and rackBase.Parent then rackBase.Transparency = 0 end
		end)
	end)
end

-------------------------------------------------
-- Fabric Bin Setup (tag: FabricBins) - drive-by collision
-------------------------------------------------
local function setupFabricBin(bin)
	for _, child in ipairs(bin:GetDescendants()) do
		if child:IsA("ProximityPrompt") then child:Destroy() end
	end

	local hitbox = bin:FindFirstChild("DepositHitbox")
	if not hitbox then
		hitbox = Instance.new("Part")
		hitbox.Name = "DepositHitbox"
		hitbox.Size = BIN_HITBOX_SIZE
		hitbox.Transparency = 1
		hitbox.CanCollide = false
		hitbox.Anchored = true
		local binBase = bin:IsA("BasePart") and bin or bin:FindFirstChildWhichIsA("BasePart")
		if binBase then hitbox.CFrame = binBase.CFrame end
		hitbox.Parent = bin
	else
		hitbox.Size = BIN_HITBOX_SIZE
	end

	local depositing = {}

	hitbox.Touched:Connect(function(hit)
		local character = hit.Parent
		local player = Players:GetPlayerFromCharacter(character)
		if not player then return end
		if not (player.Team and player.Team.Name == Config.DesignerTeamName) then return end
		if depositing[player.UserId] then return end

		local fabricTool = character:FindFirstChild("FBRoll") or player.Backpack:FindFirstChild("FBRoll")
		if not fabricTool then return end

		-- Server-side distance check
		local root = character:FindFirstChild("HumanoidRootPart")
		local binBase = bin:IsA("BasePart") and bin or bin:FindFirstChildWhichIsA("BasePart")
		if root and binBase then
			local dist = (root.Position - binBase.Position).Magnitude
			if dist > MAX_INTERACTION_DISTANCE then
				warn("[EXPLOIT] " .. player.Name .. " tried to deposit from " .. dist .. " studs away.")
				return
			end
		end

		depositing[player.UserId] = true

		local depositPos = binBase and binBase.Position or Vector3.zero

		print("[FABRIC] " .. player.Name .. " dunked fabric!")
		fabricTool:Destroy()
		addGlobalFabric(1, player)

		-- Deposit sound and VFX
		SoundService.FireToAll("FabricDunk", depositPos)
		DepositVFX:FireAllClients(depositPos)

		-- Rewards
		if _G.DataManager then
			_G.DataManager.AddXP(player, 25)
			_G.DataManager.AddCoins(player, 10)
		end

		-- Showstopper charge
		if _G.ShowstopperService then
			_G.ShowstopperService.OnFabricDunk(player)
		end

		-- Reward pop-up on client
		ShowRewardPopup:FireClient(player, "+25 XP", "+10 Coins")

		task.delay(0.5, function()
			depositing[player.UserId] = nil
		end)
	end)
end

-------------------------------------------------
-- Intercept-Pass detection
-- When a critic freezes a designer mid-pass, ShowstopperService gives charge.
-- FabricPassSystem sets an attribute "IsPassing" on the designer's character.
-- TagManager calls CheckDunkDenied which also checks this flag.
-------------------------------------------------
-- (Handled inside TagManager's FreezeEvent. FabricPassSystem sets
--  character attribute "IsPassing = true" during hand-off window.)

-------------------------------------------------
-- Round Reset
-------------------------------------------------
StatusText:GetPropertyChangedSignal("Value"):Connect(function()
	local val = StatusText.Value
	if val == "Intermission" or val == "Selecting Map..." or val == "Round Over!" then
		globalFabricCount = 0
		lastFiredPercentage = -1
		trendTrackerFired = false
		UpdateFabricUI:FireAllClients(0)
		print("[SYSTEM] Fabric progress reset.")
	end
end)

-------------------------------------------------
-- Initialize
-------------------------------------------------
for _, rack in ipairs(CollectionService:GetTagged("FabricRacks")) do
	setupFabricRack(rack)
end
for _, bin in ipairs(CollectionService:GetTagged("FabricBins")) do
	setupFabricBin(bin)
end

CollectionService:GetInstanceAddedSignal("FabricRacks"):Connect(setupFabricRack)
CollectionService:GetInstanceAddedSignal("FabricBins"):Connect(setupFabricBin)
