-- MVPController (LocalScript in StarterPlayerScripts)
-- Phase 4 fixes:
--  - Camera locked via RenderStepped for full 10 seconds (no drift)
--  - Post-match XP progress bar animation using GetRequiredXP math
--  - Level-up sequence if XP crosses a threshold

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService      = game:GetService("TweenService")
local RunService        = game:GetService("RunService")
local Debris            = game:GetService("Debris")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))

local Remotes      = ReplicatedStorage:WaitForChild("Remotes")
local ShowMVP      = Remotes:WaitForChild("ShowMVP")
local ShowEndStats = Remotes:WaitForChild("ShowEndStats")
local PostMatchXP  = Remotes:WaitForChild("PostMatchXP")

local screenGui = player.PlayerGui:WaitForChild("GameHUD", 5)

local function getFrame(name)
	return screenGui and screenGui:FindFirstChild(name, true)
end

-- XP math (must match DataManager)
local BASE_XP       = 100
local XP_MULTIPLIER = 1.3

local function GetRequiredXP(level)
	return math.floor(BASE_XP * (level ^ XP_MULTIPLIER))
end

-------------------------------------------------
-- Camera lock via RenderStepped
-------------------------------------------------
local camLockConn
local camTarget     = nil
local camStartCF    = nil
local camEndOffset  = Vector3.new(0, 3, 6)
local camStartOffset = Vector3.new(0, 10, 20)
local camZoomStart  = 0

local function startMVPCamera(mvpPlayer)
	local char = mvpPlayer.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	camera.CameraType = Enum.CameraType.Scriptable
	camTarget    = root
	camZoomStart = os.clock()

	-- Disconnect previous lock
	if camLockConn then camLockConn:Disconnect() end

	camLockConn = RunService.RenderStepped:Connect(function()
		if not camTarget or not camTarget.Parent then
			camLockConn:Disconnect()
			return
		end

		local elapsed  = os.clock() - camZoomStart
		local zoomDur  = 4  -- seconds for zoom
		local alpha    = math.min(elapsed / zoomDur, 1)

		-- Interpolate offset from far to close
		local offset = camStartOffset:Lerp(camEndOffset, alpha)
		local lookTarget = camTarget.Position + Vector3.new(0, 1, 0)

		camera.CFrame = CFrame.new(camTarget.Position + offset, lookTarget)
	end)

	-- Stop after 10 seconds
	task.delay(10, function()
		if camLockConn then
			camLockConn:Disconnect()
			camLockConn = nil
		end
		camera.CameraType = Enum.CameraType.Custom
	end)
end

-------------------------------------------------
-- MVP UI
-------------------------------------------------
local function showMVPUI(mvpName, mvpUserId, mvpTitle)
	local frame      = getFrame("MVPFrame")
	local titleLabel = getFrame("MVPTitleLabel")
	local nameLabel  = getFrame("MVPNameLabel")
	local avatar     = getFrame("MVPAvatarImage")

	if not frame then return end

	if titleLabel then titleLabel.Text = mvpTitle:upper() end
	if nameLabel  then nameLabel.Text  = mvpName end

	if avatar then
		local ok, thumb = pcall(function()
			return Players:GetUserThumbnailAsync(
				mvpUserId,
				Enum.ThumbnailType.HeadShot,
				Enum.ThumbnailSize.Size420x420
			)
		end)
		if ok then avatar.Image = thumb end
	end

	frame.BackgroundTransparency = 1
	frame.Visible = true

	TweenService:Create(frame, TweenInfo.new(0.5), {BackgroundTransparency = 0}):Play()
	if titleLabel then TweenService:Create(titleLabel, TweenInfo.new(0.5), {TextTransparency = 0}):Play() end
	if nameLabel  then TweenService:Create(nameLabel,  TweenInfo.new(0.5), {TextTransparency = 0}):Play() end

	SoundService.PlayLocal("ShowstopperReady")

	-- Auto-hide after 10 seconds
	task.delay(10, function()
		TweenService:Create(frame, TweenInfo.new(0.6), {BackgroundTransparency = 1}):Play()
		task.delay(0.7, function() frame.Visible = false end)
	end)
end

-------------------------------------------------
-- XP Progress Bar Animation
-- Expected in GameHUD:
--   EndStatsFrame > XPBarBg (Frame) > XPBarFill (Frame, scales X)
--   EndStatsFrame > XPLabel (TextLabel, shows "Level X")
--   EndStatsFrame > LevelUpBanner (Frame, hidden normally)
-------------------------------------------------
local function animateXPBar(currentLevel, currentXP, xpEarned)
	local xpFill     = getFrame("XPBarFill")
	local xpLabel    = getFrame("XPLabel")
	local levelUpBanner = getFrame("LevelUpBanner")

	if not xpFill then return end

	local required   = GetRequiredXP(currentLevel)
	local startPct   = math.clamp(currentXP / required, 0, 1)
	local endXP      = currentXP + xpEarned
	local newLevel   = currentLevel
	local didLevelUp = false

	-- Simulate level-up(s)
	while endXP >= GetRequiredXP(newLevel) do
		endXP    -= GetRequiredXP(newLevel)
		newLevel += 1
		didLevelUp = true
	end

	local endPct = math.clamp(endXP / GetRequiredXP(newLevel), 0, 1)

	if xpLabel then xpLabel.Text = "Level " .. currentLevel end

	-- Start bar at current XP
	xpFill.Size = UDim2.new(startPct, 0, 1, 0)

	task.wait(0.5)

	if didLevelUp then
		-- Fill to 100%, flash, then reset and fill to new position
		TweenService:Create(xpFill, TweenInfo.new(0.8, Enum.EasingStyle.Quad), {
			Size = UDim2.new(1, 0, 1, 0)
		}):Play()
		task.wait(0.9)

		-- Flash gold on level up
		TweenService:Create(xpFill, TweenInfo.new(0.15), {
			BackgroundColor3 = Color3.fromRGB(255, 220, 0)
		}):Play()

		if levelUpBanner then
			levelUpBanner.Visible = true
			local lvlLabel = levelUpBanner:FindFirstChildOfClass("TextLabel")
			if lvlLabel then lvlLabel.Text = "LEVEL UP! " .. newLevel end
			task.delay(2, function() levelUpBanner.Visible = false end)
		end

		SoundService.PlayLocal("ShowstopperReady")
		task.wait(0.3)

		-- Reset bar and fill to new position
		xpFill.Size = UDim2.new(0, 0, 1, 0)
		if xpLabel then xpLabel.Text = "Level " .. newLevel end
	end

	-- Animate to final position
	TweenService:Create(xpFill, TweenInfo.new(1.2, Enum.EasingStyle.Quad), {
		Size = UDim2.new(endPct, 0, 1, 0)
	}):Play()
end

-------------------------------------------------
-- End Stats
-------------------------------------------------
local function showEndStats(allStats, myXP, myCoins)
	local frame      = getFrame("EndStatsFrame")
	local myXPLabel  = getFrame("MyXPLabel")
	local myCLabel   = getFrame("MyCoinsLabel")
	local list       = getFrame("LeaderboardList")

	if not frame then return end

	if myXPLabel then myXPLabel.Text  = "XP Earned: +" .. myXP end
	if myCLabel  then myCLabel.Text   = "Coins: +"    .. myCoins end

	if list then
		for _, child in ipairs(list:GetChildren()) do
			if child:IsA("TextLabel") or child:IsA("Frame") then child:Destroy() end
		end
		table.sort(allStats, function(a, b) return (a.XP or 0) > (b.XP or 0) end)
		for rank, stat in ipairs(allStats) do
			local row = Instance.new("TextLabel")
			row.Size               = UDim2.new(1, 0, 0, 30)
			row.BackgroundTransparency = 0.8
			row.TextColor3         = Color3.new(1, 1, 1)
			row.Font               = Enum.Font.GothamBold
			row.TextScaled         = true
			row.Text               = "#" .. rank .. "  " .. stat.Name
				.. "  +" .. stat.XP .. " XP  +" .. stat.Coins .. " Coins"
			row.Parent             = list
		end
	end

	frame.BackgroundTransparency = 1
	frame.Visible = true
	TweenService:Create(frame, TweenInfo.new(0.5), {BackgroundTransparency = 0}):Play()
end

-------------------------------------------------
-- PostMatchXP: server sends current level/xp + xp earned this round
-------------------------------------------------
PostMatchXP.OnClientEvent:Connect(function(currentLevel, currentXP, xpEarned)
	animateXPBar(currentLevel, currentXP, xpEarned)
end)

-------------------------------------------------
-- Remote handlers
-------------------------------------------------
ShowMVP.OnClientEvent:Connect(function(mvpName, mvpUserId, mvpTitle)
	print("[MVP] " .. mvpName .. " - " .. mvpTitle)

	local mvpPlayer
	for _, p in ipairs(Players:GetPlayers()) do
		if p.UserId == mvpUserId then mvpPlayer = p break end
	end

	showMVPUI(mvpName, mvpUserId, mvpTitle)

	if mvpPlayer and mvpPlayer.Character then
		startMVPCamera(mvpPlayer)
	end
end)

ShowEndStats.OnClientEvent:Connect(function(allStats, myXP, myCoins)
	showEndStats(allStats, myXP, myCoins)
end)

-- Panel cleanup on new round
local StatusValues = ReplicatedStorage:WaitForChild("StatusValues")
local StatusText   = StatusValues:WaitForChild("StatusText")

StatusText:GetPropertyChangedSignal("Value"):Connect(function()
	local val = StatusText.Value
	if val == "Game Starting..." or val == "Intermission" then
		local frames = {"MVPFrame", "EndStatsFrame"}
		for _, name in ipairs(frames) do
			local f = getFrame(name)
			if f then f.Visible = false end
		end
		if camLockConn then camLockConn:Disconnect() camLockConn = nil end
		camera.CameraType = Enum.CameraType.Custom
	end
end)
