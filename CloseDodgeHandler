-- CloseDodgeHandler (Script in ServerScriptService)
-- FIXED: ServiceRegistry.Await replaces _G.ShowstopperService

local ReplicatedStorage   = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")

local ServiceRegistry    = require(ServerScriptService:WaitForChild("ServiceRegistry"))
local ShowstopperService = ServiceRegistry.Await("ShowstopperService")

local Remotes        = ReplicatedStorage:WaitForChild("Remotes")
local CloseDodgeCheck = Remotes:WaitForChild("CloseDodgeCheck")

CloseDodgeCheck.OnServerEvent:Connect(function(player)
	if not (player.Team and player.Team.Name == "Designers") then return end
	ShowstopperService.OnCloseDodge(player)
	print("[DODGE] Close dodge charge awarded to " .. player.Name)
end)
