-- FabricPassSystem (Script in ServerScriptService)
-- Hot potato passing. Sets "IsPassing" attribute on character during hand-off
-- so TagManager can detect and reward Intercept Pass bonus.
-- Also awards showstopper charge to both passer and receiver.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Teams = game:GetService("Teams")
local Debris = game:GetService("Debris")

local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))

local Remotes = ReplicatedStorage:WaitForChild("Remotes")

local PassFabric = Remotes:FindFirstChild("PassFabric") or Instance.new("RemoteEvent", Remotes)
PassFabric.Name = "PassFabric"

local PlayPoofVFX = Remotes:FindFirstChild("PlayPoofVFX") or Instance.new("RemoteEvent", Remotes)
PlayPoofVFX.Name = "PlayPoofVFX"

local SetTeammateGlow = Remotes:FindFirstChild("SetTeammateGlow") or Instance.new("RemoteEvent", Remotes)
SetTeammateGlow.Name = "SetTeammateGlow"

local ShowRewardPopup = Remotes:FindFirstChild("ShowRewardPopup") or Instance.new("RemoteEvent", Remotes)
ShowRewardPopup.Name = "ShowRewardPopup"

local PASS_RANGE = 15
local DESIGNER_TEAM = "Designers"
local SCAN_INTERVAL = 0.3
local IS_PASSING_DURATION = 0.5 -- seconds the IsPassing flag is active

local passPrompts = {}

-------------------------------------------------
-- Helpers
-------------------------------------------------

local function getFabricTool(player)
	return (player.Character and player.Character:FindFirstChild("FBRoll"))
		or player.Backpack:FindFirstChild("FBRoll")
end

local function getRoot(player)
	return player.Character and player.Character:FindFirstChild("HumanoidRootPart")
end

local function getTeammatesInRange(holder, range)
	local holderRoot = getRoot(holder)
	if not holderRoot then return {} end
	local nearby = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= holder and p.Team and p.Team.Name == DESIGNER_TEAM then
			local pRoot = getRoot(p)
			if pRoot and (holderRoot.Position - pRoot.Position).Magnitude <= range then
				table.insert(nearby, p)
			end
		end
	end
	return nearby
end

-------------------------------------------------
-- Pass logic (server-authoritative)
-------------------------------------------------
PassFabric.OnServerEvent:Connect(function(holder, targetPlayer)
	if not (holder.Team and holder.Team.Name == DESIGNER_TEAM) then return end
	if not (targetPlayer and targetPlayer.Team and targetPlayer.Team.Name == DESIGNER_TEAM) then return end
	if holder == targetPlayer then return end

	local fabricTool = getFabricTool(holder)
	if not fabricTool then
		print("[PASS] " .. holder.Name .. " has no fabric to pass.")
		return
	end

	local holderRoot = getRoot(holder)
	local targetRoot = getRoot(targetPlayer)
	if not holderRoot or not targetRoot then return end

	if (holderRoot.Position - targetRoot.Position).Magnitude > PASS_RANGE + 5 then
		warn("[EXPLOIT] Pass distance exploit by " .. holder.Name)
		return
	end

	if getFabricTool(targetPlayer) then
		print("[PASS] " .. targetPlayer.Name .. " already has fabric.")
		return
	end

	print("[PASS] " .. holder.Name .. " -> " .. targetPlayer.Name)

	-- Set IsPassing flag so TagManager can detect intercept
	if holder.Character then
		holder.Character:SetAttribute("IsPassing", true)
		task.delay(IS_PASSING_DURATION, function()
			if holder.Character then
				holder.Character:SetAttribute("IsPassing", nil)
			end
		end)
	end

	-- Poof at holder
	PlayPoofVFX:FireAllClients(holderRoot.Position)
	SoundService.FireToAll("FabricPass", holderRoot.Position)

	-- Move tool
	fabricTool.Parent = targetPlayer.Backpack

	-- Poof at target
	task.wait(0.1)
	if targetRoot then
		PlayPoofVFX:FireAllClients(targetRoot.Position)
	end

	-- Showstopper charge for both
	if _G.ShowstopperService then
		_G.ShowstopperService.OnFabricPass(holder, targetPlayer)
	end

	-- Reward pop-ups
	ShowRewardPopup:FireClient(holder, "+10 Showstopper", "")
	ShowRewardPopup:FireClient(targetPlayer, "+10 Showstopper", "")
end)

-------------------------------------------------
-- Intercept detection: called from TagManager when a critic freezes a designer
-- If the designer's character has IsPassing = true, award Intercept bonus
-------------------------------------------------
-- (TagManager checks character:GetAttribute("IsPassing") before calling
--  ShowstopperService.OnInterceptPass(critic))

-------------------------------------------------
-- Continuous scan: pass prompts and glow
-------------------------------------------------
local function updatePassSystem()
	for _, holder in ipairs(Players:GetPlayers()) do
		if not (holder.Team and holder.Team.Name == DESIGNER_TEAM) then
			if passPrompts[holder.UserId] then
				passPrompts[holder.UserId]:Destroy()
				passPrompts[holder.UserId] = nil
			end
			continue
		end

		local hasFabric = getFabricTool(holder) ~= nil
		local holderChar = holder.Character
		local holderRoot = holderChar and holderChar:FindFirstChild("HumanoidRootPart")

		if hasFabric and holderRoot then
			local nearby = getTeammatesInRange(holder, PASS_RANGE)

			if #nearby > 0 then
				SetTeammateGlow:FireClient(holder, nearby, true)

				if not passPrompts[holder.UserId] then
					local prompt = Instance.new("ProximityPrompt")
					prompt.ActionText = "Pass Fabric"
					prompt.ObjectText = "Pass to Teammate"
					prompt.HoldDuration = 0
					prompt.RequiresLineOfSight = false
					prompt.MaxActivationDistance = PASS_RANGE
					prompt.Parent = holderRoot

					prompt.Triggered:Connect(function(teammate)
						if not (teammate.Team and teammate.Team.Name == DESIGNER_TEAM) then return end
						if teammate == holder then return end
						if getFabricTool(teammate) then return end
						PassFabric:FireServer(teammate)
					end)

					passPrompts[holder.UserId] = prompt
				end
			else
				SetTeammateGlow:FireClient(holder, {}, false)
				if passPrompts[holder.UserId] then
					passPrompts[holder.UserId]:Destroy()
					passPrompts[holder.UserId] = nil
				end
			end
		else
			SetTeammateGlow:FireClient(holder, {}, false)
			if passPrompts[holder.UserId] then
				passPrompts[holder.UserId]:Destroy()
				passPrompts[holder.UserId] = nil
			end
		end
	end
end

task.spawn(function()
	while true do
		task.wait(SCAN_INTERVAL)
		updatePassSystem()
	end
end)

Players.PlayerRemoving:Connect(function(p)
	if passPrompts[p.UserId] then
		passPrompts[p.UserId]:Destroy()
		passPrompts[p.UserId] = nil
	end
end)
