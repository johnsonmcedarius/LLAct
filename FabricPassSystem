local Players             = game:GetService("Players")
local ReplicatedStorage   = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")

local ServiceRegistry = require(ServerScriptService:WaitForChild("ServiceRegistry"))

-- Await hard dependencies
local ShowstopperService = ServiceRegistry.Await("ShowstopperService")

local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))

local Remotes = ReplicatedStorage:WaitForChild("Remotes")

local function getRemote(name)
	local r = Remotes:FindFirstChild(name)
	if not r then r = Instance.new("RemoteEvent") r.Name = name r.Parent = Remotes end
	return r
end

local PassFabric      = getRemote("PassFabric")
local PlayPoofVFX     = getRemote("PlayPoofVFX")
local SetTeammateGlow = getRemote("SetTeammateGlow")
local ShowRewardPopup = getRemote("ShowRewardPopup")
local SetPromptVisible = getRemote("SetPromptVisible") -- fires only to designers

local PASS_RANGE     = 15
local DESIGNER_TEAM  = "Designers"
local SCAN_INTERVAL  = 0.3
local IS_PASSING_DUR = 0.5

-- [holderUserId][targetUserId] = prompt
local passPrompts = {}

local function getFabricTool(player)
	return (player.Character and player.Character:FindFirstChild("FBRoll"))
		or player.Backpack:FindFirstChild("FBRoll")
end

local function getRoot(player)
	return player.Character and player.Character:FindFirstChild("HumanoidRootPart")
end

local function getTeammatesInRange(holder, range)
	local hr = getRoot(holder)
	if not hr then return {} end
	local nearby = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p == holder then continue end
		if not (p.Team and p.Team.Name == DESIGNER_TEAM) then continue end
		local pr = getRoot(p)
		if pr and (hr.Position - pr.Position).Magnitude <= range then
			table.insert(nearby, p)
		end
	end
	return nearby
end

-- ── The Logic (Moved to a shared function) ──────────────────────────────────
local function executePass(holder, targetPlayer)
	if not (holder.Team and holder.Team.Name == DESIGNER_TEAM) then return end
	if not (targetPlayer and targetPlayer.Team and targetPlayer.Team.Name == DESIGNER_TEAM) then return end
	if holder == targetPlayer then return end

	local fabricTool = getFabricTool(holder)
	if not fabricTool then return end

	local hr = getRoot(holder)
	local tr = getRoot(targetPlayer)
	if not hr or not tr then return end

	-- Exploit check
	if (hr.Position - tr.Position).Magnitude > PASS_RANGE + 10 then return end
	if getFabricTool(targetPlayer) then return end

	print("[PASS] " .. holder.Name .. " -> " .. targetPlayer.Name)

	-- Visual feedback
	if holder.Character then
		holder.Character:SetAttribute("IsPassing", true)
		task.delay(IS_PASSING_DUR, function()
			if holder.Character then holder.Character:SetAttribute("IsPassing", nil) end
		end)
	end

	PlayPoofVFX:FireAllClients(hr.Position)
	SoundService.FireToAll("FabricPass", hr.Position)

	-- INVENTORY TO INVENTORY PASS
	fabricTool.Parent = targetPlayer.Backpack

	task.wait(0.1)
	if tr then PlayPoofVFX:FireAllClients(tr.Position) end

	ShowstopperService.OnFabricPass(holder, targetPlayer)

	-- Optional DailyLookbook
	local lb = ServiceRegistry.Get("DailyLookbook")
	if lb then
		lb.AddProgress(holder,       "Passes", 1)
		lb.AddProgress(targetPlayer, "Passes", 1)
	end

	ShowRewardPopup:FireClient(holder,       "+10 Showstopper", "")
	ShowRewardPopup:FireClient(targetPlayer, "+10 Showstopper", "")
end

-- Remote still works for manual/client triggers
PassFabric.OnServerEvent:Connect(executePass)

-- ── Pass Management ──────────────────────────────────────────────────────────
local function updatePassSystem()
	for _, holder in ipairs(Players:GetPlayers()) do
		local uid = holder.UserId
		passPrompts[uid] = passPrompts[uid] or {}

		local hasFabric  = getFabricTool(holder) ~= nil
		local holderRoot = getRoot(holder)

		if hasFabric and holderRoot and (holder.Team and holder.Team.Name == DESIGNER_TEAM) then
			local nearby = getTeammatesInRange(holder, PASS_RANGE)
			SetTeammateGlow:FireClient(holder, nearby, true)

			-- Create/Update prompts on nearby teammates
			local currentNearbyIds = {}
			for _, teammate in ipairs(nearby) do
				local tUid = teammate.UserId
				currentNearbyIds[tUid] = true

				if not passPrompts[uid][tUid] then
					local tRoot = getRoot(teammate)
					if tRoot then
						local prompt = Instance.new("ProximityPrompt")
						prompt.ActionText   = "Give Fabric"
						prompt.ObjectText   = "Pass to " .. teammate.Name
						prompt.HoldDuration = 0
						prompt.MaxActivationDistance = 8
						prompt.RequiresLineOfSight   = false
						prompt.Enabled      = false  -- Hidden server-side; critics won't see it
						prompt.Parent = tRoot
						-- Show only to the holder (the one with the fabric roll)
						SetPromptVisible:FireClient(holder, prompt, true)

						prompt.Triggered:Connect(function(playerWhoTriggered)
							-- Only the person holding the fabric can trigger this specific pass
							if playerWhoTriggered == holder then
								executePass(holder, teammate)
							end
						end)
						passPrompts[uid][tUid] = prompt
					end
				end
			end

			-- Cleanup teammates who moved out of range
			for tUid, prompt in pairs(passPrompts[uid]) do
				if not currentNearbyIds[tUid] then
					if prompt then prompt:Destroy() end
					passPrompts[uid][tUid] = nil
				end
			end
		else
			-- Holder lost fabric or isn't a designer: wipe their prompts
			SetTeammateGlow:FireClient(holder, {}, false)
			for tUid, prompt in pairs(passPrompts[uid]) do
				if prompt then prompt:Destroy() end
			end
			passPrompts[uid] = {}
		end
	end
end

task.spawn(function()
	while true do
		task.wait(SCAN_INTERVAL)
		updatePassSystem()
	end
end)

Players.PlayerRemoving:Connect(function(p)
	local uid = p.UserId
	if passPrompts[uid] then
		for _, prompt in pairs(passPrompts[uid]) do
			if prompt then prompt:Destroy() end
		end
		passPrompts[uid] = nil
	end
end)
