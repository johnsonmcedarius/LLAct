-- HighHeelTrapHandler (Script in ServerScriptService)
-- Spawns floor traps server-side when a Designer activates the HighHeel tool.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Debris = game:GetService("Debris")

local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))

local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local PlaceHeelTrap = Remotes:WaitForChild("PlaceHeelTrap")

local STUN_DURATION = 3
local TRAP_LIFETIME = 10
local DESIGNER_TEAM = "Designers"
local CRITIC_TEAM = "Critics"

PlaceHeelTrap.OnServerEvent:Connect(function(player, trapPosition)
	-- Validate: must be Designer
	if not (player.Team and player.Team.Name == DESIGNER_TEAM) then return end

	-- Anti-exploit: trap must be near the player
	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not root then return end
	if (root.Position - trapPosition).Magnitude > 20 then
		warn("[EXPLOIT] " .. player.Name .. " tried to place trap too far away.")
		return
	end

	print("[HEELTRAP] " .. player.Name .. " placed a trap at " .. tostring(trapPosition))

	-- Create trap hitbox
	local trap = Instance.new("Part")
	trap.Name = "HighHeelTrap"
	trap.Size = Vector3.new(4, 0.5, 4)
	trap.CFrame = CFrame.new(trapPosition)
	trap.Anchored = true
	trap.CanCollide = false
	trap.Transparency = 0.5
	trap.BrickColor = BrickColor.new("Hot pink")
	trap.Material = Enum.Material.Neon
	trap.Parent = workspace

	SoundService.FireToAll("HeelThud", trapPosition)

	local triggered = false

	trap.Touched:Connect(function(hit)
		if triggered then return end

		local victimChar = hit.Parent
		local victimPlayer = Players:GetPlayerFromCharacter(victimChar)
		local hum = victimChar:FindFirstChildOfClass("Humanoid")

		if victimPlayer and victimPlayer.Team and victimPlayer.Team.Name == CRITIC_TEAM and hum then
			triggered = true
			print("[HEELTRAP] " .. victimPlayer.Name .. " triggered the trap!")

			SoundService.FireToAll("AbilityHit", trap.Position)

			-- Stun
			local oldSpeed = hum.WalkSpeed
			hum.WalkSpeed = 0
			hum.PlatformStand = true

			-- Notify for showstopper charge
			if _G.ShowstopperService then
				_G.ShowstopperService.OnAbilityHit(player)
			end

			task.wait(STUN_DURATION)

			if hum then
				hum.PlatformStand = false
				hum.WalkSpeed = oldSpeed
				hum:ChangeState(Enum.HumanoidStateType.GettingUp)
			end

			Debris:AddItem(trap, 0.1)
		end
	end)

	Debris:AddItem(trap, TRAP_LIFETIME)
end)
