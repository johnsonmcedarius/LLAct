-- HighHeelTrapHandler (Script in ServerScriptService)
-- Phase 6: AbilityImmunity.TryHit() check before applying stun.
-- Diminishing returns reduce stun duration on successive hits.

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Debris            = game:GetService("Debris")

local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))
local Remotes      = ReplicatedStorage:WaitForChild("Remotes")

local function getRemote(name)
	local r = Remotes:FindFirstChild(name)
	if not r then r = Instance.new("RemoteEvent") r.Name = name r.Parent = Remotes end
	return r
end

local PlaceHeelTrap = getRemote("PlaceHeelTrap")

local BASE_STUN_DURATION = 3.0    -- seconds at full effect
local TRAP_LIFETIME      = 10
local SERVER_COOLDOWN    = 10
local MAX_DISTANCE       = 20
local DESIGNER_TEAM      = "Designers"
local CRITIC_TEAM        = "Critics"

local lastUsed = {}

PlaceHeelTrap.OnServerEvent:Connect(function(player, trapPosition)
	if not (player.Team and player.Team.Name == DESIGNER_TEAM) then return end

	local now = os.clock()
	if now - (lastUsed[player.UserId] or 0) < SERVER_COOLDOWN then
		warn("[EXPLOIT] " .. player.Name .. " PlaceHeelTrap before cooldown.")
		return
	end
	lastUsed[player.UserId] = now

	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not root then return end
	if typeof(trapPosition) ~= "Vector3" then return end
	if (root.Position - trapPosition).Magnitude > MAX_DISTANCE then
		warn("[EXPLOIT] " .. player.Name .. " trap too far.")
		return
	end

	print("[HEELTRAP] " .. player.Name .. " placed trap.")

	local trap = Instance.new("Part")
	trap.Name         = "HighHeelTrap"
	trap.Size         = Vector3.new(4, 0.5, 4)
	trap.CFrame       = CFrame.new(trapPosition)
	trap.Anchored     = true
	trap.CanCollide   = false
	trap.Transparency = 0.5
	trap.BrickColor   = BrickColor.new("Hot pink")
	trap.Material     = Enum.Material.Neon
	trap.Parent       = workspace

	SoundService.FireToAll("HeelThud", trapPosition)

	local triggered = false

	trap.Touched:Connect(function(hit)
		if triggered then return end

		local victimChar   = hit.Parent
		local victimPlayer = Players:GetPlayerFromCharacter(victimChar)
		local hum          = victimChar:FindFirstChildOfClass("Humanoid")

		if not (victimPlayer and victimPlayer.Team
			and victimPlayer.Team.Name == CRITIC_TEAM and hum) then return end

		-- ── Immunity check (Phase 6) ──
		local multiplier = _G.AbilityImmunity and _G.AbilityImmunity.TryHit(victimPlayer)
		if not multiplier then return end

		triggered = true

		local stunDuration = BASE_STUN_DURATION * multiplier

		print("[HEELTRAP] " .. victimPlayer.Name .. " stunned for "
			.. string.format("%.1f", stunDuration) .. "s (x" .. string.format("%.2f", multiplier) .. ")")

		SoundService.FireToAll("AbilityHit", trap.Position)

		local oldSpeed = hum.WalkSpeed
		hum.WalkSpeed     = 0
		hum.PlatformStand = true

		if _G.ShowstopperService then
			_G.ShowstopperService.OnAbilityHit(player)
		end
		if _G.DailyLookbook then
			_G.DailyLookbook.AddProgress(player, "Stuns", 1)
		end

		task.wait(stunDuration)

		if hum then
			hum.PlatformStand = false
			hum.WalkSpeed     = oldSpeed
			hum:ChangeState(Enum.HumanoidStateType.GettingUp)
		end

		Debris:AddItem(trap, 0.1)
	end)

	Debris:AddItem(trap, TRAP_LIFETIME)
end)

Players.PlayerRemoving:Connect(function(p)
	lastUsed[p.UserId] = nil
end)
