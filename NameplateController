-- NameplateController (LocalScript in StarterCharacterScripts)
-- Replaces default nameplate with a custom BillboardGui.
-- Designers: 3 stars above their name (disappear on each strike).
-- Critics: skull/icon above their name.
-- VIP: gold "VIP" tag next to name.
-- All driven by player attributes set by DataManager and RelevanceSystem.

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService      = game:GetService("TweenService")

local player    = Players.LocalPlayer
local character = script.Parent
local humanoid  = character:WaitForChild("Humanoid")
local head      = character:WaitForChild("Head")

-- Disable default nameplate
humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None

local Remotes         = ReplicatedStorage:WaitForChild("Remotes")
local UpdateStrikes   = Remotes:WaitForChild("UpdateStrikes")
local UpdateNameplate = Remotes:WaitForChild("UpdateNameplate")

local MAX_STRIKES = 3

-------------------------------------------------
-- Build the nameplate BillboardGui
-------------------------------------------------
local function buildNameplate()
	-- Remove old nameplate if it exists
	local old = head:FindFirstChild("CustomNameplate")
	if old then old:Destroy() end

	local billboard       = Instance.new("BillboardGui")
	billboard.Name        = "CustomNameplate"
	billboard.Size        = UDim2.fromOffset(200, 60)
	billboard.StudsOffset = Vector3.new(0, 2.5, 0)
	billboard.AlwaysOnTop = false
	billboard.MaxDistance = 50
	billboard.Parent      = head

	-- Name label
	local nameLabel             = Instance.new("TextLabel")
	nameLabel.Name              = "NameLabel"
	nameLabel.Size              = UDim2.new(1, 0, 0.55, 0)
	nameLabel.Position          = UDim2.new(0, 0, 0.45, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.TextColor3        = Color3.new(1, 1, 1)
	nameLabel.TextStrokeColor3  = Color3.new(0, 0, 0)
	nameLabel.TextStrokeTransparency = 0.5
	nameLabel.Font              = Enum.Font.GothamBold
	nameLabel.TextScaled        = true
	nameLabel.Text              = player.Name
	nameLabel.Parent            = billboard

	-- VIP tag (hidden by default)
	local vipLabel              = Instance.new("TextLabel")
	vipLabel.Name               = "VIPLabel"
	vipLabel.Size               = UDim2.new(0.35, 0, 0.35, 0)
	vipLabel.Position           = UDim2.new(0.65, 0, 0, 0)
	vipLabel.BackgroundColor3   = Color3.fromRGB(255, 200, 0)
	vipLabel.BackgroundTransparency = 0.1
	vipLabel.TextColor3         = Color3.fromRGB(80, 50, 0)
	vipLabel.Font               = Enum.Font.GothamBold
	vipLabel.TextScaled         = true
	vipLabel.Text               = "VIP"
	vipLabel.Visible            = false
	vipLabel.Parent             = billboard
	Instance.new("UICorner", vipLabel).CornerRadius = UDim.new(0.3, 0)

	-- Stars container (designers only)
	local starsFrame       = Instance.new("Frame")
	starsFrame.Name        = "StarsFrame"
	starsFrame.Size        = UDim2.new(0.6, 0, 0.42, 0)
	starsFrame.Position    = UDim2.new(0.2, 0, 0, 0)
	starsFrame.BackgroundTransparency = 1
	starsFrame.Parent      = billboard

	local starLayout       = Instance.new("UIListLayout")
	starLayout.FillDirection = Enum.FillDirection.Horizontal
	starLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	starLayout.Padding      = UDim.new(0.05, 0)
	starLayout.Parent       = starsFrame

	local stars = {}
	for i = 1, MAX_STRIKES do
		local star = Instance.new("TextLabel")
		star.Name               = "Star" .. i
		star.Size               = UDim2.new(0, 18, 1, 0)
		star.BackgroundTransparency = 1
		star.TextColor3         = Color3.fromRGB(255, 220, 0)
		star.Font               = Enum.Font.GothamBold
		star.TextScaled         = true
		star.Text               = "★"
		star.Parent             = starsFrame
		stars[i]                = star
	end

	starsFrame.Visible = false  -- hidden until assigned Designer role

	return billboard, nameLabel, vipLabel, starsFrame, stars
end

local billboard, nameLabel, vipLabel, starsFrame, stars = buildNameplate()

-------------------------------------------------
-- Role assignment
-------------------------------------------------
local function updateRole()
	local team = player.Team
	if not team then return end

	if team.Name == "Designers" then
		starsFrame.Visible  = true
		nameLabel.TextColor3 = Color3.fromRGB(100, 200, 255)
	elseif team.Name == "Critics" then
		starsFrame.Visible  = false
		nameLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
	else
		starsFrame.Visible  = false
		nameLabel.TextColor3 = Color3.new(1, 1, 1)
	end
end

player:GetPropertyChangedSignal("Team"):Connect(updateRole)
updateRole()

-------------------------------------------------
-- VIP detection
-------------------------------------------------
local function checkVIP()
	local isVIP = player:GetAttribute("IsVIP") or false
	vipLabel.Visible = isVIP
end

player:GetAttributeChangedSignal("IsVIP"):Connect(checkVIP)
checkVIP()

-------------------------------------------------
-- Strike display (Updates LOCAL player stars)
-------------------------------------------------
UpdateStrikes.OnClientEvent:Connect(function(strikeCount, maxStrikes)
	-- Re-use the existing logic to update the local 'stars' table
	for i = 1, MAX_STRIKES do
		local star = stars[i]
		if not star then continue end

		if i <= strikeCount then
			star.Text = "✕"
			star.TextColor3 = Color3.fromRGB(60, 60, 60)
		else
			star.Text = "★"
			star.TextColor3 = Color3.fromRGB(255, 220, 0)
		end
	end
end)

-------------------------------------------------
-- Remote nameplate updates (Handles seeing OTHER players)
-------------------------------------------------
UpdateNameplate.OnClientEvent:Connect(function(targetPlayer, data)
	if targetPlayer == player then
		-- Handled by the local UpdateStrikes listener above
		return
	end

	local char = targetPlayer.Character
	if not char then return end
	local h = char:FindFirstChild("Head")
	if not h then return end

	local bp = h:FindFirstChild("CustomNameplate")
	if not bp then return end

	if data.strikes then
		local sf = bp:FindFirstChild("StarsFrame")
		if sf then
			for i = 1, MAX_STRIKES do
				local s = sf:FindFirstChild("Star" .. i)
				if s then
					if i <= data.strikes then
						s.Text = "✕"
						s.TextColor3 = Color3.fromRGB(60, 60, 60)
					else
						s.Text = "★"
						s.TextColor3 = Color3.fromRGB(255, 220, 0)
					end
				end
			end
		end
	end
end)
