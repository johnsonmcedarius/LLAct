-------------------------------------------------
-- RACK STATE CHANGED VFX (Phase 3)
-------------------------------------------------
RackStateChanged.OnClientEvent:Connect(function(rack, sabotaged)
	if not rack or not rack.Parent then return end
	local rackBase = rack:IsA("BasePart") and rack or rack:FindFirstChildWhichIsA("BasePart")
	local pos = rackBase and rackBase.Position or Vector3.zero

	if sabotaged then
		local glitch = Instance.new("Part")
		glitch.Size = Vector3.new(3, 3, 3)
		glitch.Shape = Enum.PartType.Ball
		glitch.Position = pos
		glitch.Anchored = true
		glitch.CanCollide = false
		glitch.Material = Enum.Material.Neon
		glitch.BrickColor = BrickColor.new("Really black")
		glitch.Parent = workspace

		TweenService:Create(glitch, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = Vector3.new(8, 8, 8),
			Transparency = 1,
		}):Play()
		Debris:AddItem(glitch, 0.4)

		local emitterPart = Instance.new("Part")
		emitterPart.Size = Vector3.new(0.1, 0.1, 0.1)
		emitterPart.Position = pos
		emitterPart.Anchored = true
		emitterPart.Transparency = 1
		emitterPart.CanCollide = false
		emitterPart.Parent = workspace

		local emitter = Instance.new("ParticleEmitter")
		emitter.Texture = "rbxasset://textures/particles/smoke_main.dds"
		emitter.Rate = 0
		emitter.Lifetime = NumberRange.new(0.5, 1.2)
		emitter.Speed = NumberRange.new(5, 12)
		emitter.SpreadAngle = Vector2.new(180, 180)
		emitter.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(60, 0, 0)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(150, 0, 0)),
		})
		emitter.Size = NumberSequence.new(0.5, 0)
		emitter.Parent = emitterPart
		emitter:Emit(30)
		Debris:AddItem(emitterPart, 2)

		SoundService.PlayLocal("HairsprayHiss")
	else
		local restore = Instance.new("Part")
		restore.Size = Vector3.new(1, 1, 1)
		restore.Shape = Enum.PartType.Ball
		restore.Position = pos
		restore.Anchored = true
		restore.CanCollide = false
		restore.Material = Enum.Material.Neon
		restore.BrickColor = BrickColor.new("Carnation pink")
		restore.Parent = workspace

		TweenService:Create(restore, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = Vector3.new(5, 5, 5),
			Transparency = 1,
		}):Play()
		Debris:AddItem(restore, 0.5)
		SoundService.PlayLocal("FabricPickup")
	end
end)

