-- STRIKES & ELIMINATION
-------------------------------------------------
UpdateStrikes.OnClientEvent:Connect(function(strikes, maxStrikes)
	for i = 1, maxStrikes do
		local strikeIcon = getFrame("Strike" .. i)
		if strikeIcon then
			if i <= strikes then
				strikeIcon.ImageTransparency = 0.7
				strikeIcon.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
			else
				strikeIcon.ImageTransparency = 0
				strikeIcon.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
			end
		end
	end
end)

PlayerEliminated.OnClientEvent:Connect(function(eliminatedName)
	local banner = getFrame("EliminationBanner")
	if not banner then return end
	local label = banner:FindFirstChildOfClass("TextLabel")
	if label then label.Text = eliminatedName .. " HAS BEEN CANCELLED" end
	banner.Visible = true
	TweenService:Create(banner, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
	task.delay(3, function()
		TweenService:Create(banner, TweenInfo.new(0.6), {BackgroundTransparency = 1}):Play()
		task.delay(0.7, function() banner.Visible = false end)
	end)
end)

