-------------------------------------------------
-- Device Detection
-------------------------------------------------
local function getDevice()
	if UIS.TouchEnabled and not UIS.KeyboardEnabled then
		return "Mobile"
	elseif UIS.GamepadEnabled then
		return "Xbox"
	else
		return "PC"
	end
end

-------------------------------------------------
-- GUI Reference (your custom ScreenGui lives here)
-- If your ScreenGui is not named "GameHUD", change this.
-------------------------------------------------
local screenGui = player.PlayerGui:WaitForChild("GameHUD", 5)
if not screenGui then
	screenGui = Instance.new("ScreenGui")
	screenGui.Name = "GameHUD"
	screenGui.ResetOnSpawn = false
	screenGui.IgnoreGuiInset = true
	screenGui.Parent = player.PlayerGui
end

-- Helper to find or note a missing frame
local function getFrame(name)
	local f = screenGui:FindFirstChild(name, true)
	if not f then
		print("[HUD] NOTE: Frame '" .. name .. "' not found in GameHUD. Wire it up in Studio.")
	end
	return f
end

-------------------------------------------------
-- SHOWSTOPPER CHARGE BAR
-- Expected: ScreenGui > ShowstopperFrame > ChargeBar (Frame, scales X)
-------------------------------------------------
local chargeBar = getFrame("ChargeBar")

UpdateShowstopperCharge.OnClientEvent:Connect(function(charge, maxCharge)
	if not chargeBar then return end
	local pct = charge / maxCharge
	TweenService:Create(chargeBar, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
		Size = UDim2.new(pct, 0, 1, 0)
	}):Play()

	-- Color shift: grey -> gold -> hot pink at 100%
	if pct >= 1 then
		chargeBar.BackgroundColor3 = Color3.fromRGB(255, 80, 200)
	elseif pct >= 0.5 then
		chargeBar.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
	else
		chargeBar.BackgroundColor3 = Color3.fromRGB(180, 180, 180)
	end
end)

-- Charge full flash
ShowstopperFullAlert.OnClientEvent:Connect(function()
	SoundService.PlayLocal("ShowstopperReady")

	-- Flash the charge bar frame white
	local frame = getFrame("ShowstopperFrame")
	if frame then
		local original = frame.BackgroundColor3
		TweenService:Create(frame, TweenInfo.new(0.1), {BackgroundColor3 = Color3.new(1,1,1)}):Play()
		task.delay(0.15, function()
			TweenService:Create(frame, TweenInfo.new(0.3), {BackgroundColor3 = original}):Play()
		end)
	end

	-- Flash twice more
	task.delay(0.3, function()
		if frame then
			TweenService:Create(frame, TweenInfo.new(0.1), {BackgroundColor3 = Color3.new(1,1,1)}):Play()
			task.delay(0.15, function()
				if frame then TweenService:Create(frame, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(255,80,200)}):Play() end
			end)
		end
	end)
end)

-------------------------------------------------
-- ABILITY COOLDOWN OVERLAYS
-- Expected per ability: ScreenGui > AbilitySlots > [AbilityName]Slot > CooldownOverlay (Frame)
--                                                                     > CooldownLabel (TextLabel)
-------------------------------------------------
local activeCooldowns = {}

HUDCooldownUpdate.OnClientEvent:Connect(function(abilityName, duration)
	local slotName = abilityName .. "Slot"
	local slot = getFrame(slotName)
	if not slot then return end

	local overlay = slot:FindFirstChild("CooldownOverlay")
	local label = slot:FindFirstChild("CooldownLabel")

	if overlay then
		overlay.Visible = true
		overlay.BackgroundTransparency = 0.4
	end

	-- Cancel existing task for this ability
	if activeCooldowns[abilityName] then
		task.cancel(activeCooldowns[abilityName])
	end

	local startTime = os.clock()
	activeCooldowns[abilityName] = task.spawn(function()
		while true do
			local elapsed = os.clock() - startTime
			local remaining = math.max(0, duration - elapsed)

			if label then
				label.Text = string.format("%.1f", remaining) .. "s"
				label.Visible = remaining > 0
			end

			-- Shrink overlay to show progress
			if overlay then
				local pct = remaining / duration
				TweenService:Create(overlay, TweenInfo.new(0.05), {
					Size = UDim2.new(1, 0, pct, 0),
					Position = UDim2.new(0, 0, 1 - pct, 0)
				}):Play()
			end

			if remaining <= 0 then
				if overlay then overlay.Visible = false end
				if label then label.Visible = false end
				activeCooldowns[abilityName] = nil
				break
			end

			task.wait(0.05)
		end
	end)
end)

-- Fashion Dash cooldown (fired locally from StaminaSystem)
local DashCooldownUpdate = Remotes:FindFirstChild("DashCooldownUpdate") or Instance.new("RemoteEvent", Remotes)
DashCooldownUpdate.Name = "DashCooldownUpdate"

DashCooldownUpdate.OnClientEvent:Connect(function(duration)
	HUDCooldownUpdate:FireServer("Dash", duration) -- forward through server for consistency
	-- Or handle directly:
	local slot = getFrame("DashSlot")
	if not slot then return end
	local overlay = slot:FindFirstChild("CooldownOverlay")
	local label = slot:FindFirstChild("CooldownLabel")
	local start = os.clock()
	task.spawn(function()
		while true do
			local rem = math.max(0, duration - (os.clock() - start))
			if label then label.Text = string.format("%.1f", rem) .. "s" label.Visible = rem > 0 end
			if overlay then
				local pct = rem / duration
				overlay.Size = UDim2.new(1, 0, pct, 0)
				overlay.Position = UDim2.new(0, 0, 1 - pct, 0)
				overlay.Visible = rem > 0
			end
			if rem <= 0 then break end
			task.wait(0.05)
		end
	end)
end)

-------------------------------------------------
-- REWARD POP-UPS
-- Expected: ScreenGui > RewardPopup (TextLabel or Frame)
-------------------------------------------------
local popupQueue = {}
local popupActive = false

local function showNextPopup()
	if popupActive or #popupQueue == 0 then return end
	popupActive = true

	local data = table.remove(popupQueue, 1)
	local popup = getFrame("RewardPopup")
	if not popup then
		popupActive = false
		showNextPopup()
		return
	end

	popup.Text = data.xpText .. "  " .. data.coinsText
	popup.Visible = true
	popup.TextTransparency = 0
	popup.Position = UDim2.new(0.5, 0, 0.4, 0)

	-- Float up and fade
	TweenService:Create(popup, TweenInfo.new(1.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = UDim2.new(0.5, 0, 0.28, 0),
		TextTransparency = 1,
	}):Play()

	task.delay(1.3, function()
		popup.Visible = false
		popupActive = false
		showNextPopup()
	end)
end

ShowRewardPopup.OnClientEvent:Connect(function(xpText, coinsText)
	table.insert(popupQueue, {xpText = xpText, coinsText = coinsText})
	showNextPopup()
end)

-------------------------------------------------
-- ROLE REVEAL SPLASH
-- Expected: ScreenGui > RoleRevealFrame > RoleLabel (TextLabel)
-- Triggered when StatusText changes to indicate roles are assigned
-------------------------------------------------
local roleRevealShown = false

StatusText:GetPropertyChangedSignal("Value"):Connect(function()
	local val = StatusText.Value
	if not roleRevealShown and (val:find("is the Critic") or val:find("are the Critics") or val:find("Game Starting")) then
		roleRevealShown = true

		local frame = getFrame("RoleRevealFrame")
		local label = getFrame("RoleLabel")
		if not frame or not label then return end

		local team = player.Team
		if not team then return end

		if team.Name == "Critics" then
			label.Text = "YOU ARE A CRITIC"
			label.TextColor3 = Color3.fromRGB(255, 60, 60)
			SoundService.PlayLocal("RoleRevealCritic")
		elseif team.Name == "Designers" then
			label.Text = "YOU ARE A DESIGNER"
			label.TextColor3 = Color3.fromRGB(80, 200, 255)
			SoundService.PlayLocal("RoleRevealDesigner")
		else
			return
		end

		frame.BackgroundTransparency = 0
		frame.Visible = true

		-- Hold 2.5s then fade out
		task.delay(2.5, function()
			TweenService:Create(frame, TweenInfo.new(0.6), {BackgroundTransparency = 1}):Play()
			TweenService:Create(label, TweenInfo.new(0.6), {TextTransparency = 1}):Play()
			task.delay(0.7, function()
				frame.Visible = false
				label.TextTransparency = 0
			end)
		end)
	end

	-- Reset for next round
	if val == "Intermission" or val == "Round Over!" then
		roleRevealShown = false
	end
end)

-------------------------------------------------
-- TREND TRACKER BANNER (Critics)
-- Expected: ScreenGui > TrendTrackerBanner (Frame/TextLabel)
-------------------------------------------------
TrendTrackerActivate.OnClientEvent:Connect(function(duration)
	local banner = getFrame("TrendTrackerBanner")
	if not banner then return end

	banner.Visible = true
	SoundService.PlayLocal("TrendTrackerOn")

	-- Pulse the banner
	local function pulse()
		TweenService:Create(banner, TweenInfo.new(0.4), {BackgroundTransparency = 0.1}):Play()
		task.delay(0.4, function()
			TweenService:Create(banner, TweenInfo.new(0.4), {BackgroundTransparency = 0.6}):Play()
		end)
	end
	for i = 1, 3 do
		task.delay((i-1) * 0.8, pulse)
	end

	-- Hide after duration
	task.delay(duration, function()
		TweenService:Create(banner, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
		task.delay(0.6, function() banner.Visible = false end)
	end)
end)

