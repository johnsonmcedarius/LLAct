-- DEVICE-AWARE KEYBIND HINTS
-- Expected: ScreenGui > KeybindHints > DashHint, AbilityHint, ShowstopperHint (TextLabels)
-------------------------------------------------
local function updateKeybindHints()
	local device = getDevice()

	local hints = {
		DashHint        = {PC = "[Q] Dash",         Xbox = "[R1] Dash",       Mobile = "Tap DASH"},
		AbilityHint     = {PC = "[E] Ability",       Xbox = "[RB] Ability",    Mobile = "Tap ABILITY"},
		ShowstopperHint = {PC = "[F] Showstopper",   Xbox = "[Y] Showstopper", Mobile = "Tap SHOW"},
		PassHint        = {PC = "[ProximityPrompt]",  Xbox = "[X] Pass",        Mobile = "Tap PASS"},
	}

	for frameName, deviceTexts in pairs(hints) do
		local label = getFrame(frameName)
		if label then
			label.Text = deviceTexts[device] or deviceTexts["PC"]
		end
	end
end

-- Update hints when player spawns or device changes
player.CharacterAdded:Connect(updateKeybindHints)
task.delay(1, updateKeybindHints) -- initial set

