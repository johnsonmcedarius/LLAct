-------------------------------------------------
-- STRIKE DISPLAY (Relevance Meter)
-- Expected: ScreenGui > RelevanceFrame > Strike1, Strike2, Strike3 (ImageLabels or Frames)
-------------------------------------------------
UpdateStrikes.OnClientEvent:Connect(function(strikes, maxStrikes)
	for i = 1, maxStrikes do
		local strikeIcon = getFrame("Strike" .. i)
		if strikeIcon then
			-- Dim/cross-out consumed strikes
			if i <= strikes then
				strikeIcon.ImageTransparency = 0.7
				strikeIcon.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
			else
				strikeIcon.ImageTransparency = 0
				strikeIcon.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
			end
		end
	end
end)

