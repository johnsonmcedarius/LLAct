PlaySoundRemote.OnClientEvent:Connect(function(soundName, position)
	if not position then SoundService.PlayLocal(soundName) return end
	local part = Instance.new("Part")
	part.Size, part.Position, part.Anchored, part.Transparency, part.CanCollide, part.Parent = Vector3.new(0.1,0.1,0.1), position, true, 1, false, workspace
	SoundService.PlayAt(soundName, part)
	Debris:AddItem(part, 5)
end)
