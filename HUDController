local function updateKeybindHints()
	local device = getDevice()
	local hints = {
		DashHint        = {PC = "[Q] Dash",        Xbox = "[R1] Dash",     Mobile = "Tap DASH"},
		AbilityHint     = {PC = "[E] Ability",       Xbox = "[RB] Ability",    Mobile = "Tap ABILITY"},
		ShowstopperHint = {PC = "[F] Showstopper",   Xbox = "[Y] Showstopper", Mobile = "Tap SHOW"},
		PassHint        = {PC = "[ProximityPrompt]", Xbox = "[X] Pass",        Mobile = "Tap PASS"},
	}
	for frameName, deviceTexts in pairs(hints) do
		local label = getFrame(frameName)
		if label then label.Text = deviceTexts[device] or deviceTexts["PC"] end
	end
end

player.CharacterAdded:Connect(updateKeybindHints)
task.delay(1, updateKeybindHints)

-------------------------------------------------
-- BLIND / DAZED / CAMERA SHAKE
-------------------------------------------------
BlindClient.OnClientEvent:Connect(function(duration)
	local overlay = getFrame("BlindOverlay")
	if not overlay then return end
	overlay.BackgroundTransparency = 0
	overlay.Visible = true
	task.delay(duration * 0.6, function()
		TweenService:Create(overlay, TweenInfo.new(duration * 0.4), {BackgroundTransparency = 1}):Play()
		task.delay(duration * 0.4 + 0.1, function() overlay.Visible = false end)
	end)
end)

PlayDazedAnim.OnClientEvent:Connect(function(duration)
	local char = player.Character
	if not char or DAZED_ANIMATION_ID == "rbxassetid://0" then return end
	local hum = char:FindFirstChildOfClass("Humanoid")
	local animator = hum and hum:FindFirstChildOfClass("Animator")
	if not animator then return end

	local anim = Instance.new("Animation")
	anim.AnimationId = DAZED_ANIMATION_ID
	local track = animator:LoadAnimation(anim)
	track.Priority = Enum.AnimationPriority.Action2
	track:Play()
	task.delay(duration, function() if track then track:Stop() end end)
end)

CameraShake.OnClientEvent:Connect(function()
	local startTime = os.clock()
	local shakeDuration, shakeIntensity = 0.5, 0.4
	local connection
	connection = RunService.RenderStepped:Connect(function()
		local elapsed = os.clock() - startTime
		if elapsed >= shakeDuration then connection:Disconnect() return end
		local decay = 1 - (elapsed / shakeDuration)
		local offset = Vector3.new((math.random()-0.5)*shakeIntensity*decay, (math.random()-0.5)*shakeIntensity*decay, 0)
		camera.CFrame = camera.CFrame * CFrame.new(offset)
	end)
end)

