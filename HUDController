-- Showstopper charge bar (kept here as it's closely tied to single UI frame)
local UpdateShowstopperCharge = Remotes:WaitForChild("UpdateShowstopperCharge")
local ShowstopperFullAlert    = Remotes:WaitForChild("ShowstopperFullAlert")

UpdateShowstopperCharge.OnClientEvent:Connect(function(charge, maxCharge)
	local bar = getFrame("ChargeBar")
	if not bar then return end
	local pct = charge / maxCharge
	TweenService:Create(bar, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
		Size = UDim2.new(pct, 0, 1, 0)
	}):Play()
	if pct >= 1 then
		bar.BackgroundColor3 = Color3.fromRGB(255, 80, 200)
	elseif pct >= 0.5 then
		bar.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
	else
		bar.BackgroundColor3 = Color3.fromRGB(180, 180, 180)
	end
end)

ShowstopperFullAlert.OnClientEvent:Connect(function()
	SoundService.PlayLocal("ShowstopperReady")
	local frame = getFrame("ShowstopperFrame")
	if not frame then return end
	for i = 1, 2 do
		task.delay((i-1) * 0.3, function()
			TweenService:Create(frame, TweenInfo.new(0.1), {BackgroundColor3 = Color3.new(1,1,1)}):Play()
			task.delay(0.15, function()
				TweenService:Create(frame, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(255,80,200)}):Play()
			end)
		end)
	end
end)

-- Exit waypoint
local ShowExitWaypoint = Remotes:WaitForChild("ShowExitWaypoint")
ShowExitWaypoint.OnClientEvent:Connect(function(exitPos)
	local waypoint = getFrame("ExitWaypoint")
	if not waypoint then return end
	waypoint.Visible = true
	if waypoint:IsA("BillboardGui") then
		local marker = Instance.new("Part")
		marker.Size        = Vector3.new(1,1,1)
		marker.Position    = exitPos + Vector3.new(0,5,0)
		marker.Anchored    = true
		marker.Transparency = 1
		marker.CanCollide  = false
		marker.Parent      = workspace
		waypoint.Adornee   = marker
	end
end)

-- Sound relay
local PlaySoundRemote = Remotes:WaitForChild("PlaySound")
PlaySoundRemote.OnClientEvent:Connect(function(soundName, position)
	if not position then
		SoundService.PlayLocal(soundName)
	else
		local part = Instance.new("Part")
		part.Size        = Vector3.new(0.1, 0.1, 0.1)
		part.Position    = position
		part.Anchored    = true
		part.Transparency = 1
		part.CanCollide  = false
		part.Parent      = workspace
		SoundService.PlayAt(soundName, part)
		Debris:AddItem(part, 5)
	end
end)

-- Strikes
local UpdateStrikes = Remotes:WaitForChild("UpdateStrikes")
UpdateStrikes.OnClientEvent:Connect(function(strikes, maxStrikes)
	for i = 1, maxStrikes do
		local icon = getFrame("Strike" .. i)
		if icon then
			if i <= strikes then
				icon.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
			else
				icon.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
			end
		end
	end
end)
