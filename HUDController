-------------------------------------------------
-- Showstopper charge bar
-------------------------------------------------
local UpdateShowstopperCharge = Remotes:WaitForChild("UpdateShowstopperCharge")
local ShowstopperFullAlert    = Remotes:WaitForChild("ShowstopperFullAlert")

UpdateShowstopperCharge.OnClientEvent:Connect(function(charge, maxCharge)
	local bar = getFrame("ChargeBar")
	if not bar then return end
	local pct = charge / maxCharge
	TweenService:Create(bar, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
		Size = UDim2.new(pct, 0, 1, 0)
	}):Play()
	if pct >= 1 then
		bar.BackgroundColor3 = Color3.fromRGB(255, 80, 200)
	elseif pct >= 0.5 then
		bar.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
	else
		bar.BackgroundColor3 = Color3.fromRGB(180, 180, 180)
	end
end)

ShowstopperFullAlert.OnClientEvent:Connect(function()
	SoundService.PlayLocal("ShowstopperReady")
	local frame = getFrame("ShowstopperFrame")
	if not frame then return end
	for i = 1, 2 do
		task.delay((i-1) * 0.3, function()
			TweenService:Create(frame, TweenInfo.new(0.1), {BackgroundColor3 = Color3.new(1,1,1)}):Play()
			task.delay(0.15, function()
				TweenService:Create(frame, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(255,80,200)}):Play()
			end)
		end)
	end
end)

