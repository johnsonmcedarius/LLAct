-- SpectateSystem (Script in ServerScriptService)
-- When players are frozen or in Lobby, they can spectate.
-- Spectators can spend Coins to bet on who survives.
-- Bet availability is randomized per round to prevent match-throwing.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Teams = game:GetService("Teams")

local SoundService = require(ReplicatedStorage:WaitForChild("SoundService"))

local StatusValues = ReplicatedStorage:WaitForChild("StatusValues")
local StatusText = StatusValues:WaitForChild("StatusText")

local Remotes = ReplicatedStorage:WaitForChild("Remotes")

local StartSpectate  = Remotes:FindFirstChild("StartSpectate") or Instance.new("RemoteEvent", Remotes)
StartSpectate.Name = "StartSpectate"

local StopSpectate   = Remotes:FindFirstChild("StopSpectate") or Instance.new("RemoteEvent", Remotes)
StopSpectate.Name = "StopSpectate"

local PlaceBet       = Remotes:FindFirstChild("PlaceBet") or Instance.new("RemoteEvent", Remotes)
PlaceBet.Name = "PlaceBet"

local BetResult      = Remotes:FindFirstChild("BetResult") or Instance.new("RemoteEvent", Remotes)
BetResult.Name = "BetResult"

local UpdateBetTargets = Remotes:FindFirstChild("UpdateBetTargets") or Instance.new("RemoteEvent", Remotes)
UpdateBetTargets.Name = "UpdateBetTargets"

-- Config
local BET_COST = 50           -- Coins to place a bet
local BET_PAYOUT_MULTIPLIER = 2.5  -- Winnings multiplier
local BET_AVAILABILITY_CHANCE = 0.7 -- 70% chance betting is open any given round

-- State
local spectators = {}         -- [userId] = {target = player}
local bets = {}               -- [bettorUserId] = {target = player, amount = number}
local bettingOpen = false
local roundActive = false

-------------------------------------------------
-- Helpers
-------------------------------------------------

local function isSpectator(player)
	return player.Team and (player.Team.Name == "Lobby")
end

local function getActiveDesigners()
	local result = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Team and p.Team.Name == "Designers" then
			table.insert(result, p)
		end
	end
	return result
end

local function sendBetTargets(spectator)
	local designers = getActiveDesigners()
	local names = {}
	for _, p in ipairs(designers) do
		table.insert(names, {Name = p.Name, UserId = p.UserId})
	end
	UpdateBetTargets:FireClient(spectator, names, bettingOpen, BET_COST)
end

-------------------------------------------------
-- Spectate assignment
-------------------------------------------------
local function assignSpectateTarget(spectator)
	local designers = getActiveDesigners()
	if #designers == 0 then
		StopSpectate:FireClient(spectator)
		return
	end

	local current = spectators[spectator.UserId]
	local target

	-- Pick next designer in rotation
	if current and current.target then
		local idx = 1
		for i, p in ipairs(designers) do
			if p == current.target then idx = i break end
		end
		target = designers[(idx % #designers) + 1]
	else
		target = designers[math.random(#designers)]
	end

	spectators[spectator.UserId] = {target = target}
	StartSpectate:FireClient(spectator, target)
	print("[SPECTATE] " .. spectator.Name .. " watching " .. target.Name)
end

-- Cycle spectator view (called from client request)
local CycleSpectate = Remotes:FindFirstChild("CycleSpectate") or Instance.new("RemoteEvent", Remotes)
CycleSpectate.Name = "CycleSpectate"

CycleSpectate.OnServerEvent:Connect(function(spectator)
	if not isSpectator(spectator) then return end
	assignSpectateTarget(spectator)
end)

-- Auto-assign when player joins Lobby mid-round
Players.PlayerAdded:Connect(function(p)
	p.Changed:Connect(function(prop)
		if prop == "Team" and roundActive then
			if isSpectator(p) then
				task.wait(0.5)
				assignSpectateTarget(p)
				sendBetTargets(p)
			end
		end
	end)
end)

-------------------------------------------------
-- Betting
-------------------------------------------------
PlaceBet.OnServerEvent:Connect(function(bettor, targetUserId, amount)
	if not bettingOpen then
		print("[BET] Betting is closed this round.")
		return
	end
	if not isSpectator(bettor) then return end
	if bets[bettor.UserId] then
		print("[BET] " .. bettor.Name .. " already placed a bet this round.")
		return
	end

	-- Validate amount
	amount = BET_COST -- lock to fixed cost regardless of what client sends
	if not _G.DataManager then
		print("[BET] DataManager not available.")
		return
	end

	-- Check coins
	local coins = _G.DataManager.GetCoins(bettor)
	if not coins or coins < amount then
		print("[BET] " .. bettor.Name .. " cannot afford bet.")
		BetResult:FireClient(bettor, false, "Not enough Coins!")
		return
	end

	-- Find target
	local targetPlayer
	for _, p in ipairs(Players:GetPlayers()) do
		if p.UserId == targetUserId then targetPlayer = p break end
	end
	if not targetPlayer then
		BetResult:FireClient(bettor, false, "Player not found.")
		return
	end

	_G.DataManager.AddCoins(bettor, -amount)
	bets[bettor.UserId] = {target = targetPlayer, amount = amount}
	SoundService.FireToClient(bettor, "BetPlaced")
	BetResult:FireClient(bettor, true, "Bet placed on " .. targetPlayer.Name .. "!")
	print("[BET] " .. bettor.Name .. " bet " .. amount .. " coins on " .. targetPlayer.Name)
end)

-------------------------------------------------
-- Pay out bets at round end
-------------------------------------------------
local function resolveBets(winningTeamName)
	print("[BET] Resolving bets. Winning team: " .. tostring(winningTeamName))
	for bettorUserId, betData in pairs(bets) do
		local bettor = Players:GetPlayerByUserId(bettorUserId)
		if bettor and betData.target and betData.target.Parent then
			local targetTeam = betData.target.Team
			if targetTeam and targetTeam.Name == winningTeamName then
				local payout = math.floor(betData.amount * BET_PAYOUT_MULTIPLIER)
				if _G.DataManager then
					_G.DataManager.AddCoins(bettor, payout)
				end
				BetResult:FireClient(bettor, true, "You won! +" .. payout .. " Coins!")
				print("[BET] " .. bettor.Name .. " won " .. payout .. " coins!")
			else
				BetResult:FireClient(bettor, false, "Better luck next round!")
			end
		end
	end
	bets = {}
end

-------------------------------------------------
-- Round lifecycle
-------------------------------------------------
StatusText:GetPropertyChangedSignal("Value"):Connect(function()
	local val = StatusText.Value

	if val == "Game Starting..." then
		roundActive = true
		-- Randomize bet availability per round
		bettingOpen = math.random() < BET_AVAILABILITY_CHANCE
		if not bettingOpen then
			print("[BET] Betting CLOSED this round (randomized).")
		end
		-- Push bet targets to all current spectators/lobby players
		for _, p in ipairs(Players:GetPlayers()) do
			if isSpectator(p) then
				assignSpectateTarget(p)
				sendBetTargets(p)
			end
		end
	end

	if val:find("Win") or val == "Round Over!" or val:find("Collection") then
		roundActive = false
		-- Determine winner and resolve
		if val:find("Critics") then
			resolveBets("Critics")
		elseif val:find("Designers") or val:find("Collection") then
			resolveBets("Designers")
		else
			bets = {}
		end
		spectators = {}
		for _, p in ipairs(Players:GetPlayers()) do
			StopSpectate:FireClient(p)
		end
	end
end)

Players.PlayerRemoving:Connect(function(p)
	spectators[p.UserId] = nil
	bets[p.UserId] = nil
end)
