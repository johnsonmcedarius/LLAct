local COIN_CRATE_COST  = 500
local ROBUX_PRODUCT_ID = 0  -- TODO: Replace with your real Developer Product ID for 99 Robux

local PITY_THRESHOLD = 10  -- Guaranteed Legendary+ after this many non-Legendary spins

-- Per-player pity counters: [userId] = {CoinCrate = n, RobuxCrate = n}
local pityCounters = {}

local function getPity(player, crateType)
	if not pityCounters[player.UserId] then
		pityCounters[player.UserId] = {CoinDesignerCrate = 0, RobuxDesignerCrate = 0}
	end
	return pityCounters[player.UserId][crateType] or 0
end

local function setPity(player, crateType, value)
	if not pityCounters[player.UserId] then
		pityCounters[player.UserId] = {CoinDesignerCrate = 0, RobuxDesignerCrate = 0}
	end
	pityCounters[player.UserId][crateType] = value
end

-------------------------------------------------
-- Weighted random pull
-------------------------------------------------
local function pickItem(pool, guaranteeLegendary)
	-- Build weighted list
	local weighted = {}
	for _, item in ipairs(pool) do
		local weight = RARITY_WEIGHTS[item.Rarity] or 1
		-- If guaranteeLegendary, exclude Common/Rare/Epic
		if guaranteeLegendary then
			if item.Rarity == "Legendary" or item.Rarity == "Mythic" then
				for _ = 1, weight do table.insert(weighted, item) end
			end
		else
			for _ = 1, weight do table.insert(weighted, item) end
		end
	end

	if #weighted == 0 then
		-- Fallback: pick any Legendary
		for _, item in ipairs(pool) do
			if item.Rarity == "Legendary" then return item end
		end
		return pool[1]
	end

	return weighted[math.random(#weighted)]
end

-------------------------------------------------
-- Process a single spin
-------------------------------------------------
local function processSpin(player, crateType)
	local pool = (crateType == "CoinDesignerCrate") and CoinCratePool or RobuxCratePool

	local pity = getPity(player, crateType)
	local guarantee = pity >= PITY_THRESHOLD

	local item = pickItem(pool, guarantee)

	-- Update pity counter
	if item.Rarity == "Legendary" or item.Rarity == "Mythic" then
		setPity(player, crateType, 0)  -- reset on good pull
	else
		setPity(player, crateType, pity + 1)
	end

	-- Give item to player's inventory
	if _G.DataManager then
		_G.DataManager.GiveItem(player, item.Category, item.Name)
	end

	-- Global announcement for Mythic
	if item.Rarity == "Mythic" then
		local msg = player.Name .. " just pulled a MYTHIC: " .. item.Name .. "!"
		GlobalAnnouncement:FireAllClients(msg)
		print("[GACHA] MYTHIC PULL: " .. msg)
	end

	print("[GACHA] " .. player.Name .. " got " .. item.Name .. " (" .. item.Rarity .. ") from " .. crateType)

	return {
		Name     = item.Name,
		Category = item.Category,
		Rarity   = item.Rarity,
	}
end

-------------------------------------------------
-- Single crate open
-------------------------------------------------
OpenCrate.OnServerEvent:Connect(function(player, crateType)
	if type(crateType) ~= "string" then return end

	-- Validate crate type
	if crateType ~= "CoinDesignerCrate" and crateType ~= "RobuxDesignerCrate" then
		warn("[GACHA] Invalid crate type: " .. crateType)
		return
	end

	-- Check player has a crate in inventory (DataManager)
	if not _G.DataManager then return end
	local data = _G.DataManager.GetData(player)
	if not data then return end

	local crateCount = (data.Inventory and data.Inventory[crateType]) or 0
	if crateCount <= 0 then
		print("[GACHA] " .. player.Name .. " has no " .. crateType)
		return
	end

	-- Deduct crate
	if data.Inventory then
		data.Inventory[crateType] = math.max(0, crateCount - 1)
	end

	local result = processSpin(player, crateType)
	CrateResult:FireClient(player, crateType, result)
end)

-------------------------------------------------
-- Batch crate open (1, 5, or 10)
-------------------------------------------------
BatchOpenCrate.OnServerEvent:Connect(function(player, crateType, count)
	if type(crateType) ~= "string" then return end
	if type(count) ~= "number" then return end
	count = math.clamp(math.floor(count), 1, 10)

	if crateType ~= "CoinDesignerCrate" and crateType ~= "RobuxDesignerCrate" then return end
	if not _G.DataManager then return end

	local data = _G.DataManager.GetData(player)
	if not data then return end

	local crateCount = (data.Inventory and data.Inventory[crateType]) or 0
	local actualCount = math.min(count, crateCount)

	if actualCount <= 0 then
		print("[GACHA] " .. player.Name .. " not enough crates.")
		return
	end

	-- Deduct
	if data.Inventory then
		data.Inventory[crateType] = crateCount - actualCount
	end

	local results = {}
	for _ = 1, actualCount do
		table.insert(results, processSpin(player, crateType))
	end

	BatchCrateResults:FireClient(player, crateType, results)
end)

-------------------------------------------------
-- Coin crate purchase (spending Coins)
-------------------------------------------------
local function buyCoinCrate(player)
	if not _G.DataManager then return false end
	local coins = _G.DataManager.GetCoins(player)
	if coins < COIN_CRATE_COST then
		print("[GACHA] " .. player.Name .. " can't afford coin crate.")
		return false
	end
	_G.DataManager.AddCoins(player, -COIN_CRATE_COST)

	local data = _G.DataManager.GetData(player)
	if data then
		if not data.Inventory then data.Inventory = {} end
		data.Inventory.CoinDesignerCrate = (data.Inventory.CoinDesignerCrate or 0) + 1
	end

	print("[GACHA] " .. player.Name .. " purchased a CoinDesignerCrate.")
	return true
end

-- Expose globally for shop integration
_G.GachaService = {
	BuyCoinCrate  = buyCoinCrate,
	GetPity       = getPity,
	AddCrate      = function(player, crateType, amount)
		local data = _G.DataManager and _G.DataManager.GetData(player)
		if not data then return end
		if not data.Inventory then data.Inventory = {} end
		data.Inventory[crateType] = (data.Inventory[crateType] or 0) + (amount or 1)
	end,
}

