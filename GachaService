local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")

local ServiceRegistry = require(ServerScriptService:WaitForChild("ServiceRegistry"))
local DataManager = ServiceRegistry.Await("DataManager")
local Config = require(ReplicatedStorage:WaitForChild("SharedConfig"))

local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local CrateResult = Remotes:WaitForChild("CrateResult")
local BatchCrateResults = Remotes:WaitForChild("BatchCrateResults")
local GlobalAnnouncement = Remotes:WaitForChild("GlobalAnnouncement")

-- ── Loot Tables ──────────────────────────────────────────────────────────────
local RARITY_WEIGHTS = { Common = 60, Rare = 25, Epic = 10, Legendary = 4, Mythic = 1 }

local CoinCratePool = {
	{Name = "Lava Flow",        Category = Config.CATEGORIES.SKIN_EFFECTS, Rarity = "Legendary"},
	{Name = "Ice Shimmer",      Category = Config.CATEGORIES.SKIN_EFFECTS, Rarity = "Epic"},
	{Name = "Static Glitch",    Category = Config.CATEGORIES.SKIN_EFFECTS, Rarity = "Common"},
	{Name = "Golden Scissors",  Category = Config.CATEGORIES.WEAPON_SKINS, Rarity = "Legendary"},
	{Name = "Chrome Basic Scissors",      Category = Config.CATEGORIES.WEAPON_SKINS, Rarity = "Rare"},
	{Name = "Fashion Pulse",    Category = Config.CATEGORIES.SHOWSTOPPERS, Rarity = "Mythic"},
    {Name = "Neon Snippers",    Category = Config.CATEGORIES.WEAPON_SKINS, Rarity = "Common"},
}

local RobuxCratePool = {
	{Name = "Popstar Diva",     Category = Config.CATEGORIES.SKINS,        Rarity = "Mythic"},
	{Name = "Diamond Throne",   Category = Config.CATEGORIES.PODIUMS,      Rarity = "Mythic"},
	{Name = "Galaxy Skin",      Category = Config.CATEGORIES.SKIN_EFFECTS, Rarity = "Legendary"},
	{Name = "Runway Finale",    Category = Config.CATEGORIES.SHOWSTOPPERS, Rarity = "Legendary"},
	{Name = "Vogue Strut",      Category = Config.CATEGORIES.EMOTES,       Rarity = "Epic"},
    {Name = "Memphis Designer", Category = Config.CATEGORIES.SKINS,        Rarity = "Epic"},
}

-- ── Pity Helpers ─────────────────────────────────────────────────────────────
local function getPity(player, crateType)
	local data = DataManager.GetData(player)
	return (data and data.PityCounter and data.PityCounter[crateType]) or 0
end

local function setPity(player, crateType, value)
	local data = DataManager.GetData(player)
	if data then
		if not data.PityCounter then data.PityCounter = {} end
		data.PityCounter[crateType] = value
	end
end

-- ── Logic ────────────────────────────────────────────────────────────────────
local function pickItem(pool, guaranteeLegendary)
	local weighted = {}
	for _, item in ipairs(pool) do
		local weight = RARITY_WEIGHTS[item.Rarity] or 1
		if guaranteeLegendary then
			if item.Rarity == "Legendary" or item.Rarity == "Mythic" then
				for _ = 1, weight do table.insert(weighted, item) end
			end
		else
			for _ = 1, weight do table.insert(weighted, item) end
		end
	end
    
    -- Safety fallback if pity roll pool is empty
    if #weighted == 0 then return pool[1] end
	return weighted[math.random(#weighted)]
end

local function processSpin(player, crateType)
	local pool      = (crateType == "CoinDesignerCrate") and CoinCratePool or RobuxCratePool
	local pity      = getPity(player, crateType)
	local guarantee = pity >= Config.PITY_THRESHOLD
	local item      = pickItem(pool, guarantee)

	if item.Rarity == "Legendary" or item.Rarity == "Mythic" then
		setPity(player, crateType, 0)
	else
		setPity(player, crateType, pity + 1)
	end

	DataManager.GiveItem(player, item.Category, item.Name)

	if item.Rarity == "Mythic" then
		GlobalAnnouncement:FireAllClients(player.Name .. " just pulled a MYTHIC: " .. item.Name .. "!")
	end

	return { Name = item.Name, Category = item.Category, Rarity = item.Rarity }
end

-- ── Remote Listeners ─────────────────────────────────────────────────────────

-- Single Open
Remotes:WaitForChild("OpenCrate").OnServerEvent:Connect(function(player, crateType)
	local data = DataManager.GetData(player)
	if data and data.Inventory and (data.Inventory[crateType] or 0) > 0 then
		data.Inventory[crateType] -= 1
		local result = processSpin(player, crateType)
		CrateResult:FireClient(player, crateType, result)
	end
end)

-- Batch Open (Up to 10)
Remotes:WaitForChild("BatchOpenCrate").OnServerEvent:Connect(function(player, crateType, count)
    local count = math.clamp(math.floor(count or 1), 1, 10)
    local data = DataManager.GetData(player)
    
    if data and data.Inventory and (data.Inventory[crateType] or 0) >= count then
        data.Inventory[crateType] -= count
        local results = {}
        for i = 1, count do
            table.insert(results, processSpin(player, crateType))
        end
        BatchCrateResults:FireClient(player, crateType, results)
    end
end)

-- ── Service Methods ──────────────────────────────────────────────────────────
local GachaService = {}

function GachaService.BuyCoinCrate(player)
    local cost = Config.COIN_CRATE_COST or 500
	local coins = DataManager.GetCoins(player)
    
	if coins >= cost then
		DataManager.AddCoins(player, -cost)
		GachaService.AddCrate(player, "CoinDesignerCrate", 1)
		return true
	end
	return false
end

function GachaService.AddCrate(player, crateType, amount)
    local data = DataManager.GetData(player)
    if data then
        if not data.Inventory then data.Inventory = {} end
        data.Inventory[crateType] = (data.Inventory[crateType] or 0) + (amount or 1)
    end
end

ServiceRegistry.Register("GachaService", GachaService)
return GachaService
