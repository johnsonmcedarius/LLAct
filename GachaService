-- GachaService (Script in ServerScriptService)
-- FIXED:
--   1. Uses ServiceRegistry.Await("DataManager") — no _G race condition.
--   2. Pity counters are loaded from DataManager's persisted PityCounter on
--      player join and written back after every spin, so they survive rejoins.
--   3. RoundEvents used for round reset instead of StatusText string matching.

local Players            = game:GetService("Players")
local ReplicatedStorage  = game:GetService("ReplicatedStorage")
local MarketplaceService = game:GetService("MarketplaceService")
local ServerScriptService = game:GetService("ServerScriptService")

local ServiceRegistry = require(ServerScriptService:WaitForChild("ServiceRegistry"))

-- Await DataManager — yields until it's ready, no race condition
local DataManager = ServiceRegistry.Await("DataManager")

local Remotes = ReplicatedStorage:WaitForChild("Remotes")

local function getRemote(name)
	local r = Remotes:FindFirstChild(name)
	if not r then r = Instance.new("RemoteEvent") r.Name = name r.Parent = Remotes end
	return r
end

local OpenCrate         = getRemote("OpenCrate")
local CrateResult       = getRemote("CrateResult")
local BatchOpenCrate    = getRemote("BatchOpenCrate")
local BatchCrateResults = getRemote("BatchCrateResults")
local GlobalAnnouncement = getRemote("GlobalAnnouncement")

