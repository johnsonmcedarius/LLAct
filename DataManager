local Players         = game:GetService("Players")
local ReplicatedStorage   = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")
local MarketplaceService  = game:GetService("MarketplaceService")

local ServiceRegistry = require(ServerScriptService:WaitForChild("ServiceRegistry"))

-- ── ProfileStore & ReplicaService ───────────────────────────────────────────
local ProfileStoreFolder = ServerScriptService:WaitForChild("ProfileStore")
local ProfileStore = require(ProfileStoreFolder:WaitForChild("ProfileStore"))
local ReplicaService = require(ServerScriptService:WaitForChild("ReplicaService"):WaitForChild("ReplicaService"))

-- ── Remotes ──────────────────────────────────────────────────────────────────
local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local function getRemote(name)
	local r = Remotes:FindFirstChild(name)
	if not r then r = Instance.new("RemoteEvent") r.Name = name r.Parent = Remotes end
	return r
end
local ShowRewardPopup = getRemote("ShowRewardPopup")

-- ── Constants ────────────────────────────────────────────────────────────────
local DATA_VERSION = "v1.6" 
local PLAYER_DATA_CLASS_TOKEN = ReplicaService.NewClassToken("PlayerData")

local STARTING_DATA = {
	Coins = 500, 
	Level = 1, 
	XP = 0,
	OwnedItems = { 
		Skins = {"Default"}, 
		Weapons = {"BasicScissors"}, 
		Podiums = {"BasicPodium"},
		Abilities = {},
		Emotes = {"Wave"}
	},
	Equipped = { 
		Skin = "Default", 
		Weapon = "BasicScissors", 
		Podium = "BasicPodium",
		Ability1 = "",
		Emote = "Wave"
	},
	PityCounter = {}, 
	Inventory = { CoinDesignerCrate = 0, RobuxDesignerCrate = 0 }, 
	RedeemedCodes = {},
	LoginStreak = 0,
	LastLogin = 0,
}

local BASE_XP       = 100
local XP_MULTIPLIER = 1.3
local Profiles = {}
local Replicas = {}

-- ── Logic ────────────────────────────────────────────────────────────────────
local function GetRequiredXP(level)
	return math.floor(BASE_XP * (level ^ XP_MULTIPLIER))
end

local DataManager = {}

function DataManager.GetProfile(player)  return Profiles[player] end
function DataManager.GetData(player)     return Profiles[player] and Profiles[player].Data end
function DataManager.GetCoins(player)    return (DataManager.GetData(player) or {}).Coins or 0 end

-- // THE MASTER REWARD FUNCTION // --
function DataManager.AddReward(player, xp, coins, skipPopup)
	local profile = Profiles[player]
	local replica = Replicas[player]
	if not profile or not replica then return end

	local finalXP = xp or 0
	local finalCoins = coins or 0

	local xpMult = player:GetAttribute("XPMultiplier") or 1
	finalXP = math.floor(finalXP * xpMult)

	profile.Data.Coins = math.max(0, profile.Data.Coins + finalCoins)
	profile.Data.XP += finalXP

	local reqXP = GetRequiredXP(profile.Data.Level)
	while profile.Data.XP >= reqXP do
		profile.Data.XP -= reqXP
		profile.Data.Level += 1
		print(player.Name .. " leveled up to " .. profile.Data.Level)
		reqXP = GetRequiredXP(profile.Data.Level)
	end

	replica:SetValue({"Coins"}, profile.Data.Coins)
	replica:SetValue({"XP"}, profile.Data.XP)
	replica:SetValue({"Level"}, profile.Data.Level)
	player:SetAttribute("Level", profile.Data.Level)

	if not skipPopup and (finalXP > 0 or finalCoins > 0) then
		local xpText = finalXP > 0 and "+"..finalXP.." XP" or ""
		local coinText = finalCoins > 0 and "+"..finalCoins.." Coins" or ""
		ShowRewardPopup:FireClient(player, xpText, coinText)
	end
end

-- // EQUIPPING SYSTEM // --
function DataManager.UpdateEquipped(player, key, value)
	local profile = Profiles[player]
	local replica = Replicas[player]
	if not profile or not replica then return end

	profile.Data.Equipped[key] = value
	replica:SetValue({"Equipped", key}, value)
	player:SetAttribute("Equipped" .. key, value)
end

-- ── Helper Exports ──────────────────────────────────────────────────────────
function DataManager.AddCoins(player, amount) DataManager.AddReward(player, 0, amount, true) end
function DataManager.AddXP(player, amount) DataManager.AddReward(player, amount, 0, true) end

function DataManager.GiveItem(player, category, itemName)
	local profile = Profiles[player]
	if not profile then return false end
	local owned = profile.Data.OwnedItems[category]
	if not owned then return false end

	for _, v in ipairs(owned) do
		if v == itemName then return false end 
	end

	table.insert(owned, itemName)
	local replica = Replicas[player]
	if replica then replica:SetValue({"OwnedItems", category}, owned) end
	return true
end

function DataManager.HasItem(player, category, itemName)
	local data = DataManager.GetData(player)
	if not data then return false end
	local owned = data.OwnedItems[category]
	if not owned then return false end
	for _, v in ipairs(owned) do
		if v == itemName then return true end
	end
	return false
end

-- ── Session Management ───────────────────────────────────────────────────────
local function PlayerAdded(player)
	local store = ProfileStore.New("Player_Data_" .. DATA_VERSION, STARTING_DATA)
	local profile = store:StartSessionAsync(tostring(player.UserId))

	if profile then
		profile:Reconcile()

		profile.OnSessionEnd:Connect(function()
			Profiles[player] = nil
			if Replicas[player] then 
				Replicas[player]:Destroy() 
				Replicas[player] = nil 
			end
			if player.Parent then player:Kick("Session ended. Rejoin if this was an error!") end
		end)

		if player:IsDescendantOf(Players) then
			Profiles[player] = profile
			local replica = ReplicaService.NewReplica({
				ClassToken = PLAYER_DATA_CLASS_TOKEN,
				Data = profile.Data,
				Replication = player
			})
			Replicas[player] = replica

			-- ── LOGIN STREAK LOGIC ──
			local data = profile.Data
			local now = os.time()
			local last = data.LastLogin or 0
			local DAY_SECONDS = 86400

			-- Check if at least 24 hours have passed
			if (now - last) >= DAY_SECONDS then
				-- If they logged in within 48 hours, increment streak. Otherwise, reset to 1.
				if (now - last) <= (DAY_SECONDS * 2) then
					data.LoginStreak = (data.LoginStreak or 0) + 1
				else
					data.LoginStreak = 1 
				end

				data.LastLogin = now

				-- Reward Tiers
				if data.LoginStreak <= 6 then
					local reward = 200 * data.LoginStreak
					DataManager.AddCoins(player, reward)
					ShowRewardPopup:FireClient(player, "", "Day " .. data.LoginStreak .. " Login: +" .. reward .. " Coins!")
				elseif data.LoginStreak == 7 then
					local Gacha = ServiceRegistry.Get("GachaService")
					if Gacha then Gacha.AddCrate(player, "CoinDesignerCrate", 1) end
					ShowRewardPopup:FireClient(player, "7 DAY STREAK!", "Free Coin Crate Rewarded!")
					data.LoginStreak = 0 -- Reset cycle after big prize
				end

				-- Update Replica so UI stays synced
				replica:SetValue({"LoginStreak"}, data.LoginStreak)
				replica:SetValue({"LastLogin"}, data.LastLogin)
			end

			-- Initial Attribute Sync
			player:SetAttribute("Level", profile.Data.Level)
			for key, value in pairs(profile.Data.Equipped) do
				player:SetAttribute("Equipped" .. key, value)
			end

			print("[DATA] Successfully loaded " .. player.Name)
		else
			profile:EndSession()
		end
	else
		player:Kick("Data failed to load. Please try again.")
	end
end

Players.PlayerAdded:Connect(PlayerAdded)

for _, p in ipairs(Players:GetPlayers()) do 
	task.spawn(PlayerAdded, p) 
end

Players.PlayerRemoving:Connect(function(player)
	if Profiles[player] then 
		Profiles[player]:EndSession() 
	end
end)

ServiceRegistry.Register("DataManager", DataManager)
return DataManager
