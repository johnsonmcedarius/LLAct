-- ---- Coins ----
function DataManager.GetCoins(player)
	local p = Profiles[player]
	return p and p.Data.Coins or 0
end

function DataManager.AddCoins(player, amount)
	local profile = Profiles[player]
	local replica = Replicas[player]
	if not profile or not replica then return end

	local finalAmount = amount

	-- VIP It Girl: +20% coin bonus on positive gains
	if amount > 0 then
		local vipBonus = player:GetAttribute("VIPCoinBonus")
		if vipBonus and vipBonus > 0 then
			finalAmount = math.floor(amount * (1 + vipBonus))
		end
	end

	profile.Data.Coins = math.max(0, profile.Data.Coins + finalAmount)
	replica:SetValue({"Coins"}, profile.Data.Coins)

	if finalAmount > 0 then
		ShowRewardPopup:FireClient(player, "", "+" .. finalAmount .. " Coins")
	end
end

-- ---- XP ----
function DataManager.AddXP(player, amount)
	local profile = Profiles[player]
	local replica = Replicas[player]
	if not profile or not replica then return end

	profile.Data.XP += amount
	replica:SetValue({"XP"}, profile.Data.XP)
	CheckLevelUp(player)

	if amount > 0 then
		ShowRewardPopup:FireClient(player, "+" .. amount .. " XP", "")
	end
end

-- ---- Combined reward (with Trust Fund / Trendsetter multiplier support) ----
function DataManager.AddReward(player, xp, coins, skipPopup)
	local profile = Profiles[player]
	local replica = Replicas[player]
	if not profile or not replica then return end

	local finalXP    = xp    or 0
	local finalCoins = coins or 0

	-- Trendsetter: 2x XP at match end
	if finalXP > 0 then
		local xpMult = player:GetAttribute("XPMultiplier")
		if xpMult and xpMult > 1 then
			finalXP = math.floor(finalXP * xpMult)
		end
	end

	-- Trust Fund: 2x Coins at match end
	if finalCoins > 0 then
		local coinsMult = player:GetAttribute("CoinsMultiplier")
		if coinsMult and coinsMult > 1 then
			finalCoins = math.floor(finalCoins * coinsMult)
		end

		-- VIP coin bonus also applies here
		local vipBonus = player:GetAttribute("VIPCoinBonus")
		if vipBonus and vipBonus > 0 then
			finalCoins = math.floor(finalCoins * (1 + vipBonus))
		end
	end

	if finalXP > 0 then
		profile.Data.XP += finalXP
		replica:SetValue({"XP"}, profile.Data.XP)
		CheckLevelUp(player)
	end

	if finalCoins > 0 then
		profile.Data.Coins = math.max(0, profile.Data.Coins + finalCoins)
		replica:SetValue({"Coins"}, profile.Data.Coins)
	end

	if not skipPopup then
		local xpText    = finalXP    > 0 and ("+" .. finalXP    .. " XP")    or ""
		local coinText  = finalCoins > 0 and ("+" .. finalCoins .. " Coins") or ""
		ShowRewardPopup:FireClient(player, xpText, coinText)
	end
end

-- ---- Inventory: give a single item ----
function DataManager.GiveItem(player, category, itemName)
	local profile = Profiles[player]
	if not profile then return end

	local owned = profile.Data.OwnedItems[category]
	if not owned then
		warn("[DATA] Unknown category: " .. tostring(category))
		return
	end

	for _, v in ipairs(owned) do
		if v == itemName then return end  -- already owned
	end

	table.insert(owned, itemName)
	print("[DATA] " .. player.Name .. " unlocked: " .. itemName .. " in " .. category)
end

-- ---- Inventory: unlock a bundle ----
function DataManager.UnlockBundle(player, bundleKey)
	local Registry = require(ReplicatedStorage:WaitForChild("MarketplaceRegistry"))
	local bundle = Registry.Bundles[bundleKey]
	if not bundle then
		warn("[DATA] Bundle not found: " .. tostring(bundleKey))
		return
	end

	-- Check time window
	if not Registry.IsBundleActive(bundleKey) then
		warn("[DATA] Bundle not active: " .. bundleKey)
		return
	end

	for _, item in ipairs(bundle.Contents) do
		DataManager.GiveItem(player, item.Category, item.ItemName)
	end

	print("[DATA] " .. player.Name .. " unlocked bundle: " .. bundle.Name)
end

-- ---- Equipped slots ----
function DataManager.SetEquipped(player, slot, itemName)
	local profile = Profiles[player]
	if not profile then return end

	profile.Data.Equipped[slot] = itemName

	local attrName = ATTRIBUTE_MAP[slot]
	if attrName then
		player:SetAttribute(attrName, itemName)
	end

	print("[DATA] " .. player.Name .. " equipped " .. itemName .. " in " .. slot)
end

function DataManager.HasItem(player, category, itemName)
	local profile = Profiles[player]
	if not profile then return false end

	local owned = profile.Data.OwnedItems[category]
	if not owned then return false end

	for _, v in ipairs(owned) do
		if v == itemName then return true end
	end
	return false
end

-------------------------------------------------
-- GetProductInfo relay for Shop UI
-- Client fires this remote with a product/pass ID
-- Server calls GetProductInfoAsync and returns live price/name
-------------------------------------------------
GetProductInfoRemote.OnServerEvent:Connect(function(player, assetId, infoType)
	if type(assetId) ~= "number" then return end
	infoType = infoType or Enum.InfoType.Product

	local ok, info = pcall(function()
		return MarketplaceService:GetProductInfo(assetId, infoType)
	end)

	if ok and info then
		local PriceRelay = getRemote("ProductInfoResult")
		PriceRelay:FireClient(player, assetId, {
			Name      = info.Name,
			PriceInRobux = info.PriceInRobux,
			IsForSale = info.IsForSale,
		})
	else
		warn("[DATA] GetProductInfo failed for ID " .. tostring(assetId))
	end
end)

-------------------------------------------------
-- Player session
-------------------------------------------------
local function PlayerAdded(player)
	print("[DATA] Loading profile for " .. player.Name .. "...")

	local store   = ProfileStore.New(PROFILE_STORE_NAME, STARTING_DATA)
	local profile = store:StartSessionAsync(tostring(player.UserId))

	if profile then
		profile:Reconcile()  -- Adds any new STARTING_DATA keys to existing saves

		profile.OnSessionEnd:Connect(function()
			Profiles[player] = nil
			if Replicas[player] then
				Replicas[player]:Destroy()
				Replicas[player] = nil
			end
			if player.Parent then
				player:Kick("Your data session ended. Please rejoin.")
			end
		end)

		if player:IsDescendantOf(Players) then
			Profiles[player] = profile

			local replica = ReplicaService.NewReplica({
				ClassToken  = PLAYER_DATA_CLASS_TOKEN,
				Data        = profile.Data,
				Replication = player,
			})
			Replicas[player] = replica

			-- Sync equipped attributes
			syncEquippedAttributes(player)

			-- Login streak
			local now  = os.time()
			local last = profile.Data.LastLogin
			local diff = now - last

			if diff >= 86400 and diff < 172800 then
				profile.Data.LoginStreak += 1
			elseif diff >= 172800 then
				profile.Data.LoginStreak = 1
			end
			profile.Data.LastLogin = now
			replica:SetValue({"LoginStreak"}, profile.Data.LoginStreak)
			replica:SetValue({"LastLogin"},   profile.Data.LastLogin)

			print("[DATA] Profile loaded for " .. player.Name
				.. " | Coins: " .. profile.Data.Coins
				.. " | Level: " .. profile.Data.Level)
		else
			profile:EndSession()
		end
	else
		player:Kick("Failed to load your fashion profile. Please rejoin.")
		warn("[DATA] Failed to load profile for " .. player.Name)
	end
end

Players.PlayerAdded:Connect(PlayerAdded)
for _, p in ipairs(Players:GetPlayers()) do task.spawn(PlayerAdded, p) end

Players.PlayerRemoving:Connect(function(player)
	local profile = Profiles[player]
	if profile then
		profile:EndSession()
		print("[DATA] Session ended for " .. player.Name)
	end
	Profiles[player] = nil
	Replicas[player] = nil
end)

