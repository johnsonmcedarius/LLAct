	Skin    = "EquippedSkin",
	Weapon  = "EquippedWeapon",
	Emote   = "EquippedEmote",
}

-------------------------------------------------
-- XP / Level helpers
-------------------------------------------------
local function GetRequiredXP(level)
	return math.floor(BASE_XP * (level ^ XP_MULTIPLIER))
end

local function CheckLevelUp(player)
	local profile = Profiles[player]
	local replica = Replicas[player]
	if not profile or not replica then return end

	local data   = profile.Data
	local reqXP  = GetRequiredXP(data.Level)
	local leveled = false

	while data.XP >= reqXP do
		data.XP   -= reqXP
		data.Level += 1
		reqXP      = GetRequiredXP(data.Level)
		leveled    = true
	end

	if leveled then
		replica:SetValue({"Level"}, data.Level)
		replica:SetValue({"XP"}, data.XP)
		print("[DATA] " .. player.Name .. " leveled up to " .. data.Level)
	end
end

-------------------------------------------------
-- Attribute sync on profile load
-------------------------------------------------
local function syncEquippedAttributes(player)
	local profile = Profiles[player]
	if not profile then return end

	local equipped = profile.Data.Equipped
	for dataKey, attrName in pairs(ATTRIBUTE_MAP) do
		local val = equipped[dataKey]
		if val then player:SetAttribute(attrName, val) end
	end

	print("[DATA] Attributes synced for " .. player.Name)
end

