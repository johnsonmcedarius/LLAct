-- ── Remotes ───────────────────────────────────────────────────────────────────
local Remotes = ReplicatedStorage:WaitForChild("Remotes")

local function getRemote(name)
	local r = Remotes:FindFirstChild(name)
	if not r then r = Instance.new("RemoteEvent") r.Name = name r.Parent = Remotes end
	return r
end

local ShowRewardPopup      = getRemote("ShowRewardPopup")
local GetProductInfoRemote = getRemote("GetProductInfo")

-- ── Constants ─────────────────────────────────────────────────────────────────
local DATA_VERSION            = "v1.5"
local PROFILE_STORE_NAME      = "Player_Data_" .. DATA_VERSION
local PLAYER_DATA_CLASS_TOKEN = ReplicaService.NewClassToken("PlayerData")

-- ── Starting data ─────────────────────────────────────────────────────────────
